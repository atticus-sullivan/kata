\documentclass{article}

\input regression-test.tex\relax

\START
\SHOWFILE{\jobname.mmz}
\OMIT

\usepackage[extract=python]{memoize}
\mmzset{include context in ccmemo,trace}

\usepackage{kata}
\kataSetup{
  styled kata={section,belt,no margin},
  columns=2,
}

\makeatletter
% overwrite marginline to inspect the margin content
\renewcommand{\kata@beltmargin}[2]{%
  \TYPE{beltmargin = #1 | #2}%
  % \marginpar[{\raggedleft #1}]{\raggedright #1}%
}
\makeatother

\newbox\katabox

\begin{document}
\TIMO
%
\TEST{kata-base}{%
  \setbox\katabox=\vbox{%
  \begin{kata}[columns=3,color={waza=pink},title={Extended Example},note={blue}]
    \begin{kataStep}[head style={dashed}]
      \kataStance{stance A}{0}
      \kataWaza{technique A}{-90}
      \kataDir{center}{90}
    \end{kataStep}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}
%
\TEST{kata-base2}{%
  \setbox\katabox=\vbox{%
  \begin{kata}[columns=2,color={waza=blue},title={Extended Example 2},note={blue}]
    \begin{kataStep}
      \kataStance{stance A}{0}
    \end{kataStep}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}
%
\TEST{kata-ordinary-tikzpicture}{%
  % ensure tikzpicture's context stays clean (just an example)
  \begin{tikzpicture}
    \node[draw] {ABC};
  \end{tikzpicture}
}
%
\TEST{kata-memos}{%
  \SEPARATOR
  \TYPE{extended example -- visible step}
  \SEPARATOR
  \SHOWFILE{memoize.memo.dir/AD49BE559C145CD2E79C7530E6123CB1.memo}
  \SHOWFILE{memoize.memo.dir/AD49BE559C145CD2E79C7530E6123CB1-71E3408760193351BD5E0B035CFB1FF0.memo}
  %
  \SEPARATOR
  \TYPE{extended example 2 -- visible step}
  \SEPARATOR
  \SHOWFILE{memoize.memo.dir/B54184C7AD750E521A129E6CD355AB74.memo}
  \SHOWFILE{memoize.memo.dir/B54184C7AD750E521A129E6CD355AB74-26EA234D450BEFD4FC33A9CDE5CDE6F4.memo}
  %
  \SEPARATOR
  \TYPE{tikzpicture with clean context}
  \SEPARATOR
  \SHOWFILE{memoize.memo.dir/0A2450D890F084315497BA7BB4448C8A.memo}
  \SHOWFILE{memoize.memo.dir/0A2450D890F084315497BA7BB4448C8A-E778DCCCB8AAB0BBD3F6CFEEFD2421F8.memo}
}
%
\end{document}
