\documentclass{article}

\input regression-test.tex\relax

\usepackage{kata}

% hook into internals in order to inspect how many phantoms have been generated
\newcounter{kataTestPhantoms}
\pgfkeys{/kata/style/step phantom/.append code={\stepcounter{kataTestPhantoms}}}

% hook into internals in order to check which style was used
\pgfkeys{
  /kata/style/stance label/.append code={\TYPE{stance-label=normal}},
  /kata/style/stance label flipped/.append code={\TYPE{stance-label=flipped}},
  /kata/style/waza label/.append code={\TYPE{waza-label=normal}},
  /kata/style/waza label flipped/.append code={\TYPE{waza-label=flipped}},
  /kata/style/step phantom/.append code={\TYPE{step-phantom-style-applied}},
}

% overwrite marginline to inspect the margin content
\newcommand\marginline[1]{%
  \TYPE{marginline=\detokenize{#1}}%
  \marginpar[{\raggedleft #1}]{\raggedright #1}%
}

% One wrapper for all kata regression cases
\NewDocumentCommand{\KataTestCase}{om+m}{%
  \TEST{#2}{%
    \setcounter{kataTestPhantoms}{0}%
    #3%
    \SEPARATOR%
    \TYPE{manually added constraints}%
    \TYPE{kataTestPhantoms=\arabic{kataTestPhantoms}}%
    \IfValueT{#1}{%
      \ifnum \value{kataTestPhantoms}=#1 \else \ERROR \fi%
    }%
  }%
}

% function to dump all colors defined
\makeatletter
\newcommand\KataDumpColors{%
  \TYPE{stance=\kata@color@stance}%
  \TYPE{waza=\kata@color@waza}%
  \TYPE{dir=\kata@color@dir}%
  \TYPE{head=\kata@color@head}%
  \TYPE{border=\kata@color@border}%
  \TYPE{stepcounter=\kata@color@stepcounter}%
}
\makeatother

\tikzset{
  debugPhantomStyle/.style={
    draw=red,
    fill=red!10,
  }
}

\begin{document}
\START

%%%%%%%%%%%%%
%% PHANTOM %%
%%%%%%%%%%%%%
\part{Basic}

\KataTestCase{kata-basic}{%
  \begin{kata}[width=1]{section title}{blue}
    \begin{kataStep}
      \kataStance{stance A}{0}
      \kataWaza{technique A}{-90}
      \kataDir{center}{90}
      \kataKiai{90}
    \end{kataStep}
  \end{kata}
}

%%%%%%%%%%%%%
%% PHANTOM %%
%%%%%%%%%%%%%
\part{Phantom}

\KataTestCase[0]{kata-phantom-none}{%
  \kataSetup{step phantom style={/kata/style/step counter/.style={debugPhantomStyle}}}
  \begin{kata}[width=2]{phantom none}{blue}
    \begin{kataStep}
      \kataStance{stance A}{0}
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance B}{180}
    \end{kataStep}
  \end{kata}
}

\KataTestCase[1]{kata-phantom-one}{%
  \kataSetup{step phantom style={/kata/style/step counter/.style={debugPhantomStyle}}}
  \begin{kata}[width=2]{phantom one}{blue}
    \begin{kataStep}
      \kataStance{stance A}{0}
    \end{kataStep}
  \end{kata}
}

\KataTestCase[2]{kata-phantom-two}{%
  \kataSetup{step phantom style={/kata/style/step counter/.style={debugPhantomStyle}}}
  \begin{kata}[width=3]{phantom two}{blue}
    \begin{kataStep}
      \kataStance{stance A}{0}
    \end{kataStep}
  \end{kata}
}

\KataTestCase[1]{kata-phantom-manual}{%
  \kataSetup{step phantom style={/kata/style/step counter/.style={debugPhantomStyle}}}
  \begin{kata}[width=2]{manual phantom}{blue}
    \begin{kataStep}[phantom]
    \end{kataStep}
    \stepcounter{kata@step} % manually step because phantom does not step
    \begin{kataStep}
      \kataStance{stance A}{0}
    \end{kataStep}
  \end{kata}
}

\KataTestCase[2]{kata-phantom-mixed}{%
  \kataSetup{step phantom style={/kata/style/step counter/.style={debugPhantomStyle}}}
  \begin{kata}[width=3]{mixed phantom}{blue}
    \begin{kataStep}
      \kataStance{stance A}{0}
    \end{kataStep}
    \begin{kataStep}[phantom]
    \end{kataStep}
    \stepcounter{kata@step} % manually step because phantom does not step
  \end{kata}
}

%%%%%%%%%%%%%%%%
%% MARGINLINE %%
%%%%%%%%%%%%%%%%
\part{Marginline}

\KataTestCase{kata-marginline-text+belt}{%
  \begin{kata}[width=1]{text and belt given}{arbitrary text}[red]%
    should show text and use the custom belt color\par
    \begin{kataStep}
    \end{kataStep}
  \end{kata}
}

\KataTestCase{kata-marginline-text+emptyBelt}{%
  \begin{kata}[width=1]{text and empty belt}{arbitrary text}[]%
    should show text but no belt\par
    \begin{kataStep}
    \end{kataStep}
  \end{kata}
}

\KataTestCase{kata-marginline-text+noBelt}{%
  \begin{kata}[width=1]{text but no belt}{blue}%
    should show text and use text as belt color\par
    \begin{kataStep}
    \end{kataStep}
  \end{kata}
}

\KataTestCase{kata-marginline-emptyText+belt}{%
  \begin{kata}[width=1]{empty text but belt}{}[red]%
    should show no text but the belt\par
    \begin{kataStep}
    \end{kataStep}
  \end{kata}
}

\KataTestCase{kata-marginline-emptyText+emptyBelt}{%
  \begin{kata}[width=1]{empty text and empty belt}{}[]%
    should not draw a marginline\par
    \begin{kataStep}
    \end{kataStep}
  \end{kata}
}

\KataTestCase{kata-marginline-emptyText+noBelt}{%
  \begin{kata}[width=1]{empty text and no belt}{}%
    should not draw a marginline\par
    \begin{kataStep}
    \end{kataStep}
  \end{kata}
}

%%%%%%%%%%%%%%%%%%%%%%%%%
%% STEP COUNTER FORMAT %%
%%%%%%%%%%%%%%%%%%%%%%%%%
\part{Step counter formatting}

\KataTestCase{kata-stepcnt-default}{%
  \begin{kata}[width=1]{step counter default}{blue}
    \begin{kataStep}
    \end{kataStep}
    \begin{kataStep}
    \end{kataStep}
  \end{kata}
}

\KataTestCase{kata-stepcnt-roman}{%
    \renewcommand\kataStepCnt[1]{\roman{#1}}%
    \begin{kata}[width=1]{step counter roman}{blue}
      \begin{kataStep}
      \end{kataStep}
      \begin{kataStep}
      \end{kataStep}
    \end{kata}
}

\KataTestCase{kata-stepcnt-local}{%
  only the second image should have a roman counter\par
  \begin{kata}[width=1]{step counter local}{blue}
    \begin{kataStep}
    \end{kataStep}
    {%
      \renewcommand\kataStepCnt[1]{\roman{#1}}%
      \begin{kataStep}
      \end{kataStep}
    }%
    \begin{kataStep}
    \end{kataStep}
  \end{kata}
}

