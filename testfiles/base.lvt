\documentclass{article}

\input regression-test.tex\relax

\usepackage{kata}

\kataSetup{
  styled kata={section,belt,no margin},
  columns=2,
}

% make the phantoms visible to check it in the output
\makeatletter
\kata@phantomsteprule@width=4pt
\makeatother


% hook into internals in order to check which style was used
\pgfkeys{
  /kata/style/stance label/.append code={\TYPE{stance-label=normal}},
  /kata/style/stance label flipped/.append code={\TYPE{stance-label=flipped}},
  /kata/style/waza label/.append code={\TYPE{waza-label=normal}},
  /kata/style/waza label flipped/.append code={\TYPE{waza-label=flipped}},
}

\makeatletter
% overwrite marginline to inspect the margin content
\renewcommand{\kata@beltmargin@raw}[2]{%
  \TYPE{beltmargin = #1 | #2}%
  beltmargin = #1 $|$ #2\par%
}
\makeatother

% One wrapper for all kata regression cases
\NewDocumentCommand{\KataTestCase}{om+m}{%
  \TEST{#2}{%
    #3%
    \SEPARATOR%
    \TYPE{manually added constraints}%
  }%
}

% function to dump all colors defined
\makeatletter
\newcommand\KataDumpColors{%
  \TYPE{stance=\kata@color@stance}%
  \TYPE{waza=\kata@color@waza}%
  \TYPE{dir=\kata@color@dir}%
  \TYPE{head=\kata@color@head}%
  \TYPE{border=\kata@color@border}%
  \TYPE{stepcounter=\kata@color@stepcounter}%
}
\makeatother

\tikzset{
  debugPhantomStyle/.style={
    draw=red,
    fill=red!10,
  }
}

\newbox\katabox

\begin{document}
\START

%%%%%%%%%%%
%% BASIC %%
%%%%%%%%%%%
\part{Basic}

\KataTestCase{kata-basic}{%
  \setbox\katabox=\vbox{%
    \begin{kata}[title={section title},note={blue}]
      \begin{kataStep}
        \kataStance{stance A}{0}
        \kataWaza{technique A}{-90}
        \kataDir{center}{90}
        \kataKiai{90}
      \end{kataStep}
    \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}

\section{Raw}
\KataTestCase{kata-basic-raw}{%
  \setbox\katabox=\vbox{%
    \begin{kataRaw}[columns=1]
      \begin{kataStep}
        \kataStance{stance A}{0}
        \kataWaza{technique A}{-90}
        \kataDir{center}{90}
        \kataKiai{90}
      \end{kataStep}
    \end{kataRaw}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}

%%%%%%%%%%%%%
%% PHANTOM %%
%%%%%%%%%%%%%
\part{Phantom}

\KataTestCase{kata-phantom-none}{%
  \setbox\katabox=\vbox{%
    \begin{kata}[columns=2,title={phantom none},note={blue}]
    \begin{kataStep}
      \kataStance{stance A}{0}
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance B}{180}
    \end{kataStep}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}

\KataTestCase{kata-phantom-one}{%
  \setbox\katabox=\vbox{%
    \begin{kata}[columns=2,title={phantom one},note={blue}]
    \begin{kataStep}
      \kataStance{stance A}{0}
    \end{kataStep}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}

\KataTestCase{kata-phantom-two}{%
  \begin{minipage}{15cm}
  \setbox\katabox=\vbox{%
  \begin{kata}[columns=3,title={phantom two},note={blue}]
    \begin{kataStep}
      \kataStance{stance A}{0}
    \end{kataStep}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
  \end{minipage}
}

\KataTestCase{kata-phantom-manual}{%
  \setbox\katabox=\vbox{%
  \begin{kata}[columns=2,title={manual phantom},note={blue}]
    should show: manual phantom | step (2 cols)\par
    \kataStepPhantom%
    \begin{kataStep}
      \kataStance{stance A}{0}
    \end{kataStep}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}

\KataTestCase{kata-phantom-mixed}{%
  \begin{minipage}{15cm}
  \setbox\katabox=\vbox{%
  \begin{kata}[columns=3,title={mixed phantom},note={blue}]
    should show: step | manual phantom | automatic phantom (3 cols)\par
    \begin{kataStep}
      \kataStance{stance A}{0}
    \end{kataStep}
    \kataStepPhantom
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
  \end{minipage}
}


%%%%%%%%%%%%%%%%%%%%%%
%% Alignment / Grid %%
%%%%%%%%%%%%%%%%%%%%%%
\part{Alignment / Grid}
Tests implicitly \verb|kata@step@interspace| and \verb|\kataStepPhantom|

\KataTestCase{kata-full-grid}{%
  \begin{minipage}{15cm}
  \setbox\katabox=\vbox{%
  \setlength{\textwidth}{15cm}
  \begin{kata}[columns=3,title={full grid},note={blue}]
    \begin{kataStep}
    \end{kataStep}
    \kataStepPhantom
    \begin{kataStep}
    \end{kataStep}
    %
    \begin{kataStep}
    \end{kataStep}
    \begin{kataStep}
    \end{kataStep}
    \begin{kataStep}
    \end{kataStep}
    %
    \begin{kataStep}
    \end{kataStep}
    \begin{kataStep}
    \end{kataStep}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
  \end{minipage}
}

\subsection{Raw}
\KataTestCase{kata-raw-full-grid}{%
  \begin{minipage}{15cm}
  \setbox\katabox=\vbox{%
  \setlength{\textwidth}{15cm}
  \begin{kataRaw}[columns=3]
    \begin{kataStep}
    \end{kataStep}
    \kataStepPhantom
    \begin{kataStep}
    \end{kataStep}
    %
    \begin{kataStep}
    \end{kataStep}
    \begin{kataStep}
    \end{kataStep}
    \begin{kataStep}
    \end{kataStep}
    %
    \begin{kataStep}
    \end{kataStep}
    \begin{kataStep}
    \end{kataStep}
  \end{kataRaw}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
  \end{minipage}
}

