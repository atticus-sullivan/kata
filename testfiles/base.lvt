\part{prefix/side arguments}

\KataTestCase{kata-prefix-stance}{%
  \begin{kata}[width=1]{stance}{blue}
    \begin{kataStep}
      \kataStance{stance A}{0}
      \kataStance[R]{stance A}{90}
      \kataStance[L]{stance B}{180}
      \kataStance[arbitrary]{stance C}{-90}
    \end{kataStep}
  \end{kata}
}

\KataTestCase{kata-prefix-waza}{%
  \begin{kata}[width=1]{waza}{blue}
