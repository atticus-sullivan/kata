%%%%%%%%%%%%%%%%%%%%%%%%%
%% STEP COUNTER FORMAT %%
%%%%%%%%%%%%%%%%%%%%%%%%%
\part{Step counter formatting}

\KataTestCase{kata-stepcnt-default}{%
  \setbox\katabox=\vbox{%
    \begin{kata}[title={step counter default},note={blue}]
    \begin{kataStep}
    \end{kataStep}
    \begin{kataStep}
    \end{kataStep}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}

\KataTestCase{kata-stepcnt-roman}{%
  \setbox\katabox=\vbox{%
    \renewcommand\kataStepCnt[1]{\roman{#1}}%
    \begin{kata}[title={step counter roman},note={blue}]
      \begin{kataStep}
      \end{kataStep}
      \begin{kataStep}
      \end{kataStep}
    \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}

\KataTestCase{kata-stepcnt-local}{%
  \setbox\katabox=\vbox{%
  only the second image should have a roman counter\par
  \begin{kata}[title={step counter local},note={blue}]
    \begin{kataStep}
    \end{kataStep}
    {%
      \renewcommand\kataStepCnt[1]{\roman{#1}}%
      \begin{kataStep}
      \end{kataStep}
    }%
    \begin{kataStep}
    \end{kataStep}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}

