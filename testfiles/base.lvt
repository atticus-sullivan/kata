    \begin{kataStep}[step counter style={dashed}]
    \end{kataStep}
    \begin{kataStep}
    \end{kataStep}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}
\KataTestCase{kata-stepcounter-style-global}{%
