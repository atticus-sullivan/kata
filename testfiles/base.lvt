\part{PGF-Keys -- color}

\KataTestCase{kata-color-kata}{%
  \setbox\katabox=\vbox{%
    \begin{kata}[color={stance=red,waza=green,dir=cyan,head=black,border=gray,step counter=purple},title={colors kata},note={blue}]
    \begin{kataStep}
      \kataStance{stance A}{0}
      \kataWaza{technique A}{90}
      \kataDir{0}{180}
      \KataDumpColors
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance A}{0}
      \kataWaza{technique A}{90}
      \kataDir{0}{180}
      \KataDumpColors
    \end{kataStep}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}

\KataTestCase{kata-color-step}{%
  \setbox\katabox=\vbox{%
    \begin{kata}[title={colors step},note={blue}]
    \begin{kataStep}[color={stance=red,waza=green,dir=cyan,head=black,border=gray,step counter=purple}]
      \kataStance{stance A}{0}
      \kataWaza{technique A}{90}
      \kataDir{0}{180}
      \KataDumpColors
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance A}{0}
      \kataWaza{technique A}{90}
      \kataDir{0}{180}
      \KataDumpColors
    \end{kataStep}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}

\KataTestCase{kata-color-global}{%
  \setbox\katabox=\vbox{%
  \kataSetup{color={stance=red,waza=green,dir=cyan,head=black,border=gray,step counter=purple}}
  \begin{kata}[title={colors global},note={blue}]
    \begin{kataStep}
      \kataStance{stance A}{0}
      \kataWaza{technique A}{90}
      \kataDir{0}{180}
      \KataDumpColors
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance A}{0}
      \kataWaza{technique A}{90}
      \kataDir{0}{180}
      \KataDumpColors
    \end{kataStep}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}

\KataTestCase{kata-color-local}{%
  \setbox\katabox=\vbox{%
    \begin{kata}[color={stance=red,waza=green,dir=cyan,head=black,border=gray,step counter=purple},title={colors local},note={blue}]
    \begin{kataStep}
      \kataStance{stance A}{0}[color=orange]
      \kataWaza{technique A}{90}[color=brown]
      \kataDir[color=magenta]{0}{180}
      \KataDumpColors
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance A}{0}[color=orange]
      \kataWaza{technique A}{90}[color=brown]
      \kataDir[color=magenta]{0}{180}
      \KataDumpColors
    \end{kataStep}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
