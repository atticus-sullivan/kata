%%%%%%%%%%%%%%%%
%% ANGLE ARGS %%
%%%%%%%%%%%%%%%%
\part{Angle args}

\KataTestCase{kata-angle-stance}{%
  \begin{kata}[width=1]{stance angles}{blue}
    \begin{kataStep}
      \kataStance{stance A $-360$}{-360}
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance A $0$}{0}
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance A $360$}{360}
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance B $180$}{180}
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance B $-180$}{-180}
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance C $90$}{90}
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance D $-90$}{-90}
    \end{kataStep}
  \end{kata}
}

\KataTestCase{kata-angle-waza}{%
  \begin{kata}[width=1]{waza angles}{blue}
    \begin{kataStep}
      \kataWaza{technique A $-360$}{-360}
    \end{kataStep}
    \begin{kataStep}
      \kataWaza{technique A $0$}{0}
    \end{kataStep}
    \begin{kataStep}
      \kataWaza{technique A $360$}{360}
    \end{kataStep}
    \begin{kataStep}
      \kataWaza{technique B $180$}{180}
    \end{kataStep}
    \begin{kataStep}
      \kataWaza{technique B $-180$}{-180}
    \end{kataStep}
    \begin{kataStep}
      \kataWaza{technique C $90$}{90}
    \end{kataStep}
    \begin{kataStep}
      \kataWaza{technique D $-90$}{-90}
    \end{kataStep}
  \end{kata}
}

\KataTestCase{kata-angle-kiai}{%
  \begin{kata}[width=1]{kiai angles}{blue}
    \begin{kataStep}
      \kataKiai{360}
    \end{kataStep}
    \begin{kataStep}
      \kataKiai{0}
    \end{kataStep}
    \begin{kataStep}
      \kataKiai{-360}
    \end{kataStep}
    \begin{kataStep}
      \kataKiai{180}
    \end{kataStep}
    \begin{kataStep}
      \kataKiai{-180}
    \end{kataStep}
    \begin{kataStep}
      \kataKiai{90}
    \end{kataStep}
    \begin{kataStep}
      \kataKiai{-90}
    \end{kataStep}
  \end{kata}
}

\KataTestCase{kata-angle-dir-center}{%
  \begin{kata}[width=1]{dir angles -- center}{blue}
    \begin{kataStep}
      \kataDir{center}{360}
    \end{kataStep}
    \begin{kataStep}
      \kataDir{center}{0}
    \end{kataStep}
    \begin{kataStep}
      \kataDir{center}{-360}
    \end{kataStep}
    \begin{kataStep}
      \kataDir{center}{180}
    \end{kataStep}
    \begin{kataStep}
      \kataDir{center}{-180}
    \end{kataStep}
    \begin{kataStep}
      \kataDir{center}{90}
    \end{kataStep}
    \begin{kataStep}
      \kataDir{center}{-90}
    \end{kataStep}
  \end{kata}
}

\KataTestCase{kata-angle-dir-turn}{%
  \begin{kata}[width=1]{dir angles -- turn}{blue}
    \begin{kataStep}
      \kataDir{0}{180}
    \end{kataStep}
    \begin{kataStep}
      \kataDir{180}{0}
    \end{kataStep}
    \begin{kataStep}
      \kataDir{-90}{90}
    \end{kataStep}
    \begin{kataStep}
      \kataDir{-90}{0}
    \end{kataStep}
    \begin{kataStep}
      \kataDir[flip]{-90}{0}
    \end{kataStep}
    \begin{kataStep}
      \kataDir{270}{90}
    \end{kataStep}
  \end{kata}
}

