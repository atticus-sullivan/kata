%%%%%%%%%%%%%%%%%%%%%%
%% PGF-KEYS > color %%
%%%%%%%%%%%%%%%%%%%%%%
\part{PGF-Keys -- color}

\KataTestCase{kata-color-kata}{%
  \begin{kata}[width=1,color={stance=red,waza=green,dir=cyan,head=black,border=gray,step counter=purple}]{colors kata}{blue}
    \begin{kataStep}
      \kataStance{stance A}{0}
      \kataWaza{technique A}{90}
      \kataDir{0}{180}
      \KataDumpColors
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance A}{0}
      \kataWaza{technique A}{90}
      \kataDir{0}{180}
      \KataDumpColors
    \end{kataStep}
  \end{kata}
}

\KataTestCase{kata-color-step}{%
  \begin{kata}[width=1]{colors step}{blue}
    \begin{kataStep}[color={stance=red,waza=green,dir=cyan,head=black,border=gray,step counter=purple}]
      \kataStance{stance A}{0}
      \kataWaza{technique A}{90}
      \kataDir{0}{180}
      \KataDumpColors
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance A}{0}
      \kataWaza{technique A}{90}
      \kataDir{0}{180}
      \KataDumpColors
    \end{kataStep}
  \end{kata}
}

\KataTestCase{kata-color-global}{%
  \kataSetup{color={stance=red,waza=green,dir=cyan,head=black,border=gray,step counter=purple}}
  \begin{kata}[width=1]{colors global}{blue}
    \begin{kataStep}
      \kataStance{stance A}{0}
      \kataWaza{technique A}{90}
      \kataDir{0}{180}
      \KataDumpColors
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance A}{0}
      \kataWaza{technique A}{90}
      \kataDir{0}{180}
      \KataDumpColors
    \end{kataStep}
  \end{kata}
}

\KataTestCase{kata-color-local}{%
  \begin{kata}[width=1,color={stance=red,waza=green,dir=cyan,head=black,border=gray,step counter=purple}]{colors local}{blue}
    \begin{kataStep}
      \kataStance{stance A}{0}[color=orange]
      \kataWaza{technique A}{90}[color=brown]
      \kataDir[color=magenta]{0}{180}
      \KataDumpColors
    \end{kataStep}
    \begin{kataStep}
      \kataStance{stance A}{0}[color=orange]
      \kataWaza{technique A}{90}[color=brown]
      \kataDir[color=magenta]{0}{180}
      \KataDumpColors
    \end{kataStep}
  \end{kata}
}

