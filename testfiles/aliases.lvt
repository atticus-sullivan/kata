\documentclass{article}

\input regression-test.tex\relax

\usepackage[definealiases]{kata}
\kataSetup{
  styled kata={section,belt,no margin},
  columns=2,
}

\makeatletter
% overwrite marginline to inspect the margin content
\renewcommand{\kata@beltmargin}[2]{%
  \TYPE{beltmargin = #1 | #2}%
  % \marginpar[{\raggedleft #1}]{\raggedright #1}%
}
\makeatother

% One wrapper for all kata regression cases
\newcommand\KataTestCase[2]{%
  \TEST{#1}{%
    #2%
    \SEPARATOR%
    \TYPE{manually added constraints}%
  }%
}

\newbox\katabox

\begin{document}
\START
\KataTestCase{kata-aliased-basic}{%
  \setbox\katabox=\vbox{%
  \begin{kata}[title={section title},note={blue}]
    \begin{step}
      \stance{stance A}{0}
      \waza{technique A}{-90}
      \dir{center}{90}
      \kiai{90}
    \end{step}
  \end{kata}
  }
  \showbox\katabox
  \OMIT
  \box\katabox
  \TIMO
}
\end{document}
