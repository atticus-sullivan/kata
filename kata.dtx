% \subsection{Customizations}
% There are several ways the pictograms can be customized.
% They are all drawn with tikz so you can simply change the definition of some styles for the adjustments.
% In order to make common adjustments easier there are some helpers for this.
% Think of it in multiple levels. With each level you can customize more, but also you need to know more about pgfkeys.
%
% \begin{docCommand}[]{kataStepCnt}{\marg{counter}}
% Formats the counter holding the number of the current step.
% Adjust this with e.g. \verb|\RenewDocumentCommand| or \verb|renewcommand| to change how the counter is displayed.
% \end{docCommand}
%
% \subsubsection{Level 1 -- Beginner}
% In this level you can only customize in ways which have been prepared in advance already.
% For this you can use the \refCom{katastyle} command similar like you would use \verb|\tikzset|.
% Note that the settings are bound to the scope.
% So if you change the setting within a \refEnv{kata} environment, the change will only persist until the environment is closed.
%
% \begin{docCommand}[]{katastyle}{\marg{pgfkeys-def}}
% Allows to set keys in the \verb|/kata/styles| space. The keys you can set are described in this section
% \end{docCommand}

% \begin{docKataStyKey}{border/right}{=\meta{color}}{style}
%   sets the border such that it has indicators (arrows) pointing to the right.
%   \meta{color} specifies a color for the border.
%   Also this will shade the background with 5\% of the specified color.
% \end{docKataStyKey}
% \begin{docKataStyKey}{border/left}{=\meta{color}}{style}
%   similar like \refKey{/kata/styles/border/left} but with indicators pointing to the left.
% \end{docKataStyKey}
% \begin{docKataStyKey}{border/up}{=\meta{color}}{style}
%   similar like \refKey{/kata/styles/border/left} but with indicators pointing upwards.
% \end{docKataStyKey}
% \begin{docKataStyKey}{border/down}{=\meta{color}}{style}
%   similar like \refKey{/kata/styles/border/left} but with indicators pointing downwards.
% \end{docKataStyKey}
% \begin{docKataStyKey}{border/reset}{=\meta{color}}{style}
%   resets the changes done by the keys in the \verb|/kata/styles/border| space.
% \end{docKataStyKey}
%
% The following (x)-color definitions are used when drawing the pictograms:
% \begin{itemize}
% 	\item[\docColor{KataColorHand}] used for the arrow/path showing the hand technique+direction
% 	\item[\docColor{KataColorFeet}] used for the arrow/path showing the feet technique+direction
% 	\item[\docColor{KataColorDir}] used for the indicator showing the direction of the next move/turn
% \end{itemize}
% You can set these for example via \verb|\colorlet|.
% Just make sure the modification takes place after this package got loaded.
%
% \subsubsection{Level 2 -- Advanced}
% \begin{docKataCustKey}{stepCnt}{}{style}
% Applies to the indicator with the step counter.
%
% Style which is applied after what is required for the default placement.
% You can redefine this style to adjust the appearance (in theory also the placement -- everything what tikz allows).
% \end{docKataCustKey}
% \begin{docKataCustKey}{border}{}{style}
% Applies to the border around the pictogram.
% Note: This rectangle is drawn on the background so there is no issue in using \verb|fill|.
%
% Style which is applied after what is required for the default placement.
% You can redefine this style to adjust the appearance (in theory also the placement -- everything what tikz allows).
% \end{docKataCustKey}
%
% \paragraph{Helpers: Border}
% For the \refKey{/kata/customize/border} there are some helper styles which can be used (nor (re)defined) to aid in the customization.
%
% \begin{docKataBorderKey}{arrowRL}{=\meta{direction}}{style}
% Draws two arrows on the path. If the path is a rectangle, one will be on the top, one on the bottom.
% Both point in the same direction specified with \meta{direction}.
%
% This way arrows pointing right/left are drawn correctly (hance the name).
% \end{docKataBorderKey}
% \begin{docKataBorderKey}{arrowUD}{=\meta{direction}}{style}
% Draws two arrows on the path. If the path is a rectangle, one will be on the right, one on the left.
% Both point in the same direction specified with \meta{direction}.
%
% This way arrows pointing up/down are drawn correctly (hance the name).
% \end{docKataBorderKey}
%
% \subsection{Extended Example}
% Note this code is \enquote{run} after the box showing the code. Because of the use of \verb|\marginline| it was not possible to wrap this in \verb|dispExample*|. Also this way the \verb|\section| command will leak and insert a new section to this documentation.
%<*doc>
\begin{dispListing*}{listing options={language=[LaTeX]TeX}}
\begin{kata}[width=3]{Extended Example}{blue}
	Some explanation -- normal \LaTeX code
	\parindent=0pt

	\colorlet{KataColorHand}{green!50!black}
	\begin{step}
		\feet{stance A}{0}
		\waza{technique A}{-90}
		\dir{center}{90}
	\end{step}
	\colorlet{KataColorDir}{brown}
	\katastyle{border/up=pink}
	\begin{step}
		\feet{stance B}{180}
		\waza{technique B}{90}
		\dir{90}{180}
	\end{step}
	\katastyle{border/reset}
	\renewcommand\kataStepCnt[1]{\roman{#1}}
	\begin{step}
		\feet{stance B}{180}
		\waza[flip]{technique B}{90}
		\dir[flip]{90}{180}
	\end{step}
	\pgfkeys{
		/kata/customize/stepCnt/.style={xshift=1em},
		/kata/customize/border/.style={/kata/border/arrowUD=45},
	}
	\begin{step}
		\feet{stance C}{180}
		\waza{technique D}{0}
	\end{step}
\end{kata}
\end{dispListing*}
\begin{kata}[width=3]{Example}{blue}
	Some explanation -- normal \LaTeX code
	\parindent=0pt

	\colorlet{KataColorHand}{green!50!black}
	\begin{step}
		\feet{stance A}{0}
		\waza{technique A}{-90}
		\dir{center}{90}
	\end{step}
	\colorlet{KataColorDir}{brown}
	\katastyle{border/up=pink}
	\begin{step}
		\feet{stance B}{180}
		\waza{technique B}{90}
		\dir{90}{180}
	\end{step}
	\katastyle{border/reset}
	\renewcommand\kataStepCnt[1]{\roman{#1}}
	\begin{step}
		\feet{stance B}{180}
		\waza[flip]{technique B}{90}
		\dir[flip]{90}{180}
	\end{step}
	\\
	\pgfkeys{
		/kata/customize/stepCnt/.style={xshift=1em},
		/kata/customize/border/.style={/kata/border/arrowUD=45},
	}
	\begin{step}
		\feet{stance C}{180}
		\waza{technique D}{0}
	\end{step}
\end{kata}
