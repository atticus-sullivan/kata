% \subsubsection{Presets} \label{sec:presets}
% In order to make common but more complex style modifications easier, this package defines some \emph{presets} which can usually be applied with the respective \verb|<> preset| key.
%
% \paragraph{Presets for the border} \label{sec:presets:border}
% \begin{docKeys}[doc keypath=kata/preset/border]{{doc name=arrow up},{doc name=arrow down},{doc name=arrow right},{doc name=arrow left}}
%   Adjust \refKey{/kata/step/border style} by appending so that the border shows two arrows.
%   The arrows are placed on opposite sides of the rectangle both pointing in the same direction.
%
%   Which direction depends on which of the keys is chosen. The two sides showing the arrows are the following:
%   \begin{itemize}
%     \item edge on the \emph{right} and \emph{left} side for \refKey{/kata/preset/border/arrow up} and \refKey{/kata/preset/border/arrow down}
%     \item edge on the \emph{top} and \emph{bottom} side for \refKey{/kata/preset/border/arrow right} and \refKey{/kata/preset/border/arrow left}
%   \end{itemize}
% \end{docKeys}
%
% \begin{docKey}[kata/preset/border]{accent}{=\meta{color}}{}
%   Colors the border with \meta{color}. Also fills the border with \qty{5}{\percent} (transparent for the rest part) of that color to highlight/accent it.
%
%   As \meta{color}, everything can be passed here which \TikZ{} can use as a color.
% \end{docKey}
%
% \paragraph{Presets for steps} \label{sec:presets:step}
% \begin{docKey}[kata/preset/step]{align page bottom}{}{}
%   You usually write \refEnv{kata}s in two stages.
%   First, some additional explanations.
%   Second, the \refEnv{step}s.
%   This preset sets the steps up so they are pushed down as far as possible on the first page.
%   The idea is that this way when reading (digitally), you need to skip less space when switching from one page to the next one.
%   There is one caveat: If you don't use sections and don't place explanations before the steps, this preset might do nothing.
%
%   Note: Under the hood, this just sets \refKey{/kata/step/before first} to \verb|\vfill|.
% \end{docKey}
%
% \begin{docKey}[kata/preset/step]{align reset}{}{}
%   Undoes (locally) the changes done by \refKey{/kata/preset/step/align page bottom} etc.
%
%   Note, usually you should not need this, as setting these keys/presets is always local (setting it for one \refEnv{kata} won't affect the other ones).
% \end{docKey}
%
% \paragraph{Custom presets} \label{sec:presets:custom}
% Note: Styles (e.g. \refKey{/kata/waza/style}) are evaluated in a \verb|/tikz| context eventually.
% So if you want to declare a custom reusable style here is an example how you could declare a preset/style which only sets a background color (frame stays black) with less transparency:
%
% {\installMocks % Mocks are only used here in the docs avoid problems showing this inside the example box
%<*doc>
\begin{dispExample*}{listing options={language=[LaTeX]TeX},breakable,title={Idea how to manually define a reusable style}}
\tikzset{
  myPreset/.style={fill=#1!50},
}

\kataSetup{columns=0}

\begin{kata}
  \parindent=0pt

  \begin{step}[border style={myPreset=orange}]
    \waza{technique A}{0}
  \end{step}
\end{kata}
\end{dispExample*}
%</doc>
% }
