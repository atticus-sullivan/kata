%
% \subsubsection{Presets for styles}
% \paragraph{Helpers}
%    \begin{macrocode}
\pgfkeys{
  /kata/preset/helpers/.cd,
  arrowRL/.style={
    postaction={decorate},decoration={
      markings,
      mark=at position 0.125
        with {\pgftransformrotate{#1 - 270}\arrow[line width=2pt]{stealth}},
      mark=at position 0.625
        with {\pgftransformrotate{#1 - 270}\arrowreversed[line width=2pt]{stealth}},
    },
  },
  arrowUD/.style={
    postaction={decorate},decoration={
      markings,
      mark=at position 0.375
        with {\pgftransformrotate{#1}\arrow[line width=2pt]{stealth}},
      mark=at position 0.875
        with {\pgftransformrotate{#1}\arrowreversed[line width=2pt]{stealth}},
    },
  },
}
%    \end{macrocode}
% \paragraph{Helpers}
%    \begin{macrocode}
\pgfkeys{
  /kata/preset/border,
  arrow right/.style={
    /kata/style/border/.append style={
      /kata/preset/helpers/arrowRL=-90,
    },
  },
  arrow left/.style={
    /kata/style/border/.append style={
      /kata/preset/helpers/arrowRL=+90,
    },
  },
  arrow up/.style={
    /kata/style/border/.append style={
      /kata/preset/helpers/arrowUD=0,
    },
  },
  arrow down/.style={
    /kata/style/border/.append style={
      /kata/preset/helpers/arrowUD=180,
    },
  },
  accent/.style={
    /kata/style/border/.append style={
      fill=#1!5,
      draw=#1,
    },
  },
}
%    \end{macrocode}
