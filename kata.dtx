% \begin{macro}{\kata@beltmargin@raw}
% Takes two arguments:
% \begin{enumerate}
%   \item the note
%   \item the belt color
% \end{enumerate}
% If an argument is empty, the corresponding element will not be shown.
%    \begin{macrocode}
\newcommand{\kata@beltmargin@raw}[2]{%
  \marginline{%
    \centering\footnotesize%
    \kata@ifstr{#1}{}{}{%
      $\downarrow$ #1%
    }%
%    \end{macrocode}
% only linebreak if both are non-empty
%    \begin{macrocode}
  \kata@ifstr{#1}{}{}{\kata@ifstr{#2}{}{}{\\}}%
  \kata@ifstr{#2}{}{}{%
      \ColorBelt*[scale=0.1]{#2}%
  }%
  }%
}
%    \end{macrocode}
% \end{macro}
