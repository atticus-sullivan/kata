% \maketitle
%
% \begin{abstract}
% The \texttt{kata} package provides a compact and structured way to typeset
% martial arts katas\footnote{\url{https://en.wikipedia.org/wiki/Kata}} (forms)
% in LaTeX. It models a kata as a sequence of steps, each combining the stance
% hand/foot technique, and transition direction, and supports
% customizing the resulting pictograms for clear visual representation.
% \end{abstract}
%
% \section{Introduction}
% In many martial arts such as Karate, a kata is a predefined sequence of
% movements\footnote{\url{https://en.wikipedia.org/wiki/Kata}}.
%
% The \texttt{kata} package aims to provide a simple, structured way to
% describe katas in LaTeX. Each step of a kata is expressed as a step
% consisting of
% \begin{enumerate}
%   \item the stance with direction
%   \item a technique with direction
%   \item the direction of movement or rotation into the next step
% \end{enumerate}
% The package also offers customizing the resulting pictograms, allowing visual
% annotation of sequences, such as highlighting repetitions or emphasizing
% specific actions.
%
% \section{Usage}
% Load this package as \verb|\usepackage{kata}|.
%
% Note this package uses functionality provided by the KOMA-classes (mostly \verb|\marginline|), so it only works with such a documentclass.
%
% \begin{tcolorbox}[title={Note: Concept of \emph{direction}},fonttitle=\sffamily,colframe=orange]
%   One quite important concept is the concept of the \emph{direction}.
%   Some commands such as \refCom{waza}, \refCom{dir}, and \refCom{stance} refer to a direction in the range of -360 to 360 degrees.
%   Also some pgfkeys take a direction as an argument.
%
%   This package consistently defines the direction as follows:
%
%   \centering
%   \begin{tikzpicture}
%     \node[circle,draw] (origin) {};
%     \foreach \i/\t/\d in {0/{-90/270}/right, 90/0/above, 180/90/left, 270/180/below}{
%       \node[\d] (\i) at (\i:1) {\t};
%       \draw[-{Stealth}] (origin) -- (\i);
%     }
%   \end{tikzpicture}
% \end{tcolorbox}
%
% \begin{docEnvironment}[]{kata}{\oarg{pgfkeys}\marg{title}\marg{margin}\oarg{belt-color}}
% The container which holds an entire kata.
% Within normal \LaTeX code may be typeset but mostly the content usually consists of \refEnv{step} environments.
%
% This will also create a section named \meta{title}.
% It also adds a marginline which is thought to indicate for which belt this kata is required.
% So the marginline consists of
% \begin{itemize}
%   \item an arrow pointing down
%   \item \meta{margin}
%   \item a drawing showing a belt. The color by default will be \meta{margin} but it may be overwritten with \meta{belt-color}
%
% If \meta{margin} is empty and \meta{belt-color} is not given, no marginline will be drawn
% \end{itemize}
%
% The \oarg{pgfkeys} may be used to set keys in the \verb|/kata/cmd/kata| space.
%
% After all steps have been drawn it will add a number of phantom-steps trying to generate an even looking grid of pictograms. For this \refKey{/kata/cmd/kata/width} should be set to the number of pictograms fitting one line.
% \end{docEnvironment}
%
% \begin{docEnvironment}[]{step}{\oarg{pgfkeys}}
% Draws a pictogram representing one step in the kata.
% \meta{pgfkeys} may set any key from the space \verb|/kata/cmd/step|
%
% The body will be the content of a \verb|tikzpicture| so normal \LaTeX code won't work as expected.
%
% Usually you'll use \refCom{waza}, \refCom{stance} and \refCom{dir} to populate the step with contents.
% Note that all of these commands may be present (multiple times) but they don't need to be present all.
%
% If you're drawing manually with tikz, note the node \verb|head| exists and is at the center.
% Also be careful to not draw out of the normal bounds, ototherwise the alignment will be off.
% \end{docEnvironment}
%
% \begin{docCommand}[]{waza}{\oarg{side}\marg{content}\marg{dir}\oarg{pgfkeys}}
% Use this command to draw a technique with its direction.
% \begin{description}
%   \item[\meta{side}] may specify the side (R/L or right/left) which executes the technique
%   \item[\meta{content}] the text describing the action
%   \item[\meta{dir}] the direction in which to execute the action
%  \item[\meta{pgfkeys}] set any of the keys in the \verb|/kata/cmd/content| space. Notably is the \refKey{/kata/cmd/content/flip} key.
% \end{description}
% \end{docCommand}
%
% \begin{docCommand}[]{stance}{\oarg{side}\marg{content}\marg{dir}\oarg{pgfkeys}}
% Use this command to draw the technique+direction for the stance.
% \begin{description}
%   \item[\meta{side}] may specify the side (R/L or right/left) which executes the technique
%   \item[\meta{content}] the text describing the action
%   \item[\meta{dir}] the direction in which to execute the action
%  \item[\meta{pgfkeys}] set any of the keys in the \verb|/kata/cmd/content| space. Notably is the \refKey{/kata/cmd/content/flip} key.
% \end{description}
% \end{docCommand}
%
% \begin{docCommand}[]{dir}{\oarg{pgfkeys}\marg{dirA}\marg{dirB}}
% Use this command to draw an indicator indicating the direction/turn to transition to the next step.
%
% \begin{description}
%   \item[\meta{dirA}] is where the movement starts (in degrees -360 to 360)
%   \item[\meta{dirB}] is where the movement ends (in degrees -360 to 360)
%  \item[\meta{pgfkeys}] set any of the keys in the \verb|/kata/cmd/content| space. Notably is the \refKey{/kata/cmd/content/flip} key which causes the arc to be drawn in the other direction.
% \end{description}
%
% Note for \meta{dirA} the string \emph{center} is also eligible. This causes the arrow to start at the center of the circle, indicating only a direction not a turn.
% \end{docCommand}
%
% \begin{docCommand}[]{kiai}{\marg{dir}}
% Use this command to draw an indicator that this step involves \emph{kiai}.
% The \meta{dir} specifies in which direction to place this indicator.
% \end{docCommand}
%
% \begin{docKataContentCmdKey}{flip}{}{bool}
% Flip the \enquote{thing}.
% Usually this leads to the text-node being placed in the other direction in order to avoid collisions.
% \end{docKataContentCmdKey}
%
% \begin{docKataStepCmdKey}{first}{}{bool}
% Specify this is the first step of the kata.
% This enables various things which mostly affect the spacing.
% \end{docKataStepCmdKey}
%
% \begin{docKataStepCmdKey}{phantom}{}{style}
% Activate this style to hide this step.
% The step still occupies space but is not visible.
% \end{docKataStepCmdKey}
%
% \begin{docKataKataCmdKey}{width}{}{initially: 6}
% The number of steps fitting on one line.
% \end{docKataKataCmdKey}
%
%
% \subsection{Simple Example}
% Note:
% The output looks slightly different in the example's output here.
% Usually, the section is a proper section and the marginline is really show in the margin.
%
% {\installMocks % Mocks are only used here in the docs avoid problems showing this inside the example box
%<*doc>
\begin{dispExample*}{listing options={language=[LaTeX]TeX},breakable,title={A simple example without customizations (but includes flip)}}
\begin{kata}[width=2]{Simple Example}{blue}
  Some explanation -- normal \LaTeX code
  \parindent=0pt

  \begin{step}
    \stance{stance A}{0}
    \waza{technique A}{-90}
    \dir{center}{90}
  \end{step}
  \begin{step}
    \stance{stance A}{0}
    \dir{90}{-90}
  \end{step}
  \begin{step}
    \stance{stance A}{0}[flip]
    \dir[flip]{90}{-90}
  \end{step}
\end{kata}
\end{dispExample*}
%</doc>
% }
%
% \subsection{Customizations}
% There are several ways the pictograms can be customized.
% They are all drawn with tikz so you can simply change the definition of some styles for the adjustments.
% In order to make common adjustments easier there are some helpers for this.
% Think of it in multiple levels. With each level you can customize more, but also you need to know more about pgfkeys.
%
% \begin{docCommand}[]{kataStepCnt}{\marg{counter}}
% Formats the counter holding the number of the current step.
% Adjust this with e.g. \verb|\RenewDocumentCommand| or \verb|renewcommand| to change how the counter is displayed.
% \end{docCommand}
%
% \subsubsection{Level 1 -- Beginner}
% In this level you can only customize in ways which have been prepared in advance already.
% For this you can use the \refCom{katastyle} command similar like you would use \verb|\tikzset|.
% Note that the settings are bound to the scope.
% So if you change the setting within a \refEnv{kata} environment, the change will only persist until the environment is closed.
%
% \begin{docCommand}[]{katastyle}{\marg{pgfkeys-def}}
% Allows to set keys in the \verb|/kata/styles| space. The keys you can set are described in this section
% \end{docCommand}

% \begin{docKataStyKey}{border/right}{=\meta{color}}{style}
%   sets the border such that it has indicators (arrows) pointing to the right.
%   \meta{color} specifies a color for the border.
%   Also this will shade the background with 5\% of the specified color.
% \end{docKataStyKey}
% \begin{docKataStyKey}{border/left}{=\meta{color}}{style}
%   similar like \refKey{/kata/styles/border/left} but with indicators pointing to the left.
% \end{docKataStyKey}
% \begin{docKataStyKey}{border/up}{=\meta{color}}{style}
%   similar like \refKey{/kata/styles/border/left} but with indicators pointing upwards.
% \end{docKataStyKey}
% \begin{docKataStyKey}{border/down}{=\meta{color}}{style}
%   similar like \refKey{/kata/styles/border/left} but with indicators pointing downwards.
% \end{docKataStyKey}
% \begin{docKataStyKey}{border/reset}{=\meta{color}}{style}
%   resets the changes done by the keys in the \verb|/kata/styles/border| space.
% \end{docKataStyKey}
%
% The following (x)-color definitions are used when drawing the pictograms:
% \begin{itemize}
%   \item[\docColor{KataColorWaza}] used for the arrow/path showing a technique with its direction
%   \item[\docColor{KataColorFeet}] used for the arrow/path showing the stance with its direction
%   \item[\docColor{KataColorDir}] used for the indicator showing the direction of the next move/turn
% \end{itemize}
% You can set these for example via \verb|\colorlet|.
% Just make sure the modification takes place after this package got loaded.
%
% \subsubsection{Level 2 -- Advanced}
% \begin{docKataCustKey}{stepCnt}{}{style}
% Applies to the indicator with the step counter.
%
% Style which is applied after what is required for the default placement.
% You can redefine this style to adjust the appearance (in theory also the placement -- everything what tikz allows).
% \end{docKataCustKey}
% \begin{docKataCustKey}{border}{}{style}
% Applies to the border around the pictogram.
% Note: This rectangle is drawn on the background so there is no issue in using \verb|fill|.
%
% Style which is applied after what is required for the default placement.
% You can redefine this style to adjust the appearance (in theory also the placement -- everything what tikz allows).
% \end{docKataCustKey}
%
% \begin{docKataCustKey}{head}{}{style}
% Applies to the node showing the center which symbolizes the head.
%
% Style which is applied after what is required for the default placement.
% You can redefine this style to adjust the appearance (in theory also the placement -- everything what tikz allows).
% \end{docKataCustKey}
%
% \begin{docKataCustKey}{dir}{}{style}
% Applies to the indicator for the direction of the next move/turn.
%
% Style which is applied after what is required for the default placement.
% You can redefine this style to adjust the appearance (in theory also the placement -- everything what tikz allows).
% \end{docKataCustKey}
%
% \paragraph{Helpers: Border}
% For the \refKey{/kata/customize/border} there are some helper styles which can be used (nor (re)defined) to aid in the customization.
%
% \begin{docKataBorderKey}{arrowRL}{=\meta{direction}}{style}
% Draws two arrows on the path. If the path is a rectangle, one will be on the top, one on the bottom.
% Both point in the same direction specified with \meta{direction}.
%
% This way arrows pointing right/left are drawn correctly (hance the name).
% \end{docKataBorderKey}
% \begin{docKataBorderKey}{arrowUD}{=\meta{direction}}{style}
% Draws two arrows on the path. If the path is a rectangle, one will be on the right, one on the left.
% Both point in the same direction specified with \meta{direction}.
%
% This way arrows pointing up/down are drawn correctly (hance the name).
% \end{docKataBorderKey}
%
% \subsection{Extended Example}
% Note:
% The output looks slightly different in the example's output here.
% Usually, the section is a proper section and the marginline is really show in the margin.
%
% {\installMocks % Mocks are only used here in the docs avoid problems showing this inside the example box
%<*doc>
\begin{dispExample*}{listing options={language=[LaTeX]TeX},breakable,title={Extended example with all kinds of possible customizations}}
\installMocks % only used here to avoid problems showing inside tcolorbox
\begin{kata}[width=2,color={waza=orange}]{Extended Example}{blue}
  Some explanation -- normal \LaTeX code
  \parindent=0pt

  \begin{step}[color={stance=pink}]
    \stance{stance A}{0}
    \waza{technique A}{-90}[color=black]
    \dir{center}{90}
  \end{step}
  \kataSetup{color={dir=brown}}
  {
    \kataSetup{border preset={arrow up,accent=green}}
    \begin{step}[]
      \stance{stance B}{180}
      \waza{technique B}{90}
      \dir{90}{180}
    \end{step}
    \renewcommand\kataStepCnt[1]{\roman{#1}}
    \begin{step}
      \stance{stance B}{180}
      \waza[R]{technique B}{90}[flip]
      \dir[flip]{90}{180}
    \end{step}
  }
  \pgfkeys{
    /kata/style/step counter/.append style={xshift=1em},
    /kata/style/border/.append style={/kata/preset/helpers/arrowUD=45},
  }
  \begin{step}
    \stance{stance C}{180}
    \waza{technique D}{0}
  \end{step}
\end{kata}
\end{dispExample*}
%</doc>
% }
