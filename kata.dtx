% \begin{macro}{\kata@step@interspace}
% places a space (with glue) / a linebreak to be used between two \verb|step|s
% What exactly is placed is determined based on two parameters:
% \begin{enumerate}
%   \item the amount of columns the resulting grid should have
%   \item the index (starting at 0) of the current \verb|step|
% \end{enumerate}
% This macro assumes the space is placed \emph{before} the \verb|step|.
%    \begin{macrocode}
\newcommand{\kata@step@interspace}[2]{%
  \ifnum#1=0%
    \hskip 0.0pt plus 1.0fil %
  \else%
    \pgfmathtruncatemacro{\kata@step@column}{mod(#2,#1)}%
    \ifnum\kata@step@column=#1%
      \par
    \else%
      \hskip 0.0pt plus 1.0fil %
    \fi%
  \fi%
}%
%    \end{macrocode}
% \end{macro}
%
% \begin{macro}{\kataStepPhantom}
% Places a phantom (invisible) \verb|step| with the correct width and spacing to be consistent with the grid.
%    \begin{macrocode}
\NewDocumentCommand{\kataStepPhantom}{}{%
  \kata@step@interspace{\kata@columns}{\value{kata@step}}%
  \rule{\the\kata@phantomstep@width}{\the\kata@phantomsteprule@width}
  \refstepcounter{kata@step}
}
%    \end{macrocode}
% \end{macro}
%
% \begin{environment}{step}
% this environment always should wrap \verb|kata@step|.
% It handles the aspects of positioning the pictogram.
% Arguments:
% 1 (optional): pgfkeys
%    \begin{macrocode}
\NewDocumentEnvironment{kataStep}{O{}+b}{%
  \kata@requirekata{\string\kataStep}%
  \pgfkeys{/kata/step,#1}%
  \ifnum\value{kata@step}=0
    \kata@step@first@before\noindent%
  \else%
    \kata@step@interspace{\kata@columns}{\value{kata@step}}%
  \fi%
  \begin{kata@step}%
    #2
  \end{kata@step}%
  \refstepcounter{kata@step}
}{}
%    \end{macrocode}
% \end{environment}
%
% \begin{environment}{kata@step}
% the environment to draw everything else in
%    \begin{macrocode}
\newenvironment*{kata@step}{%
  \kata@requirekata{\string\step}%
  \begin{tikzpicture}[font=\scriptsize]%
    \begin{scope}[local bounding box=output]%
      \kata@head\kata@nothing%
      \kata@insteptrue%
}{
    \end{scope}%
%    \end{macrocode}
% Drawing the border on the background has the advantage the rectangle can be
% filled and colorize the background as well.
%    \begin{macrocode}
    \begin{scope}[on background layer]%
      \node[/kata/style/border] (t1) {};%
      \node[/kata/style/step counter] (cnt) {\kataStepCnt{kata@step}};%
    \end{scope}%
  \end{tikzpicture}%
}
%    \end{macrocode}
% \end{environment}
