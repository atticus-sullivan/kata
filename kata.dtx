% \begin{macro}{\kata@beltmargin}
% Analog to \verb|\kata@beltmargin@raw| but wraps for display policy reasons:
%
% If everything is empty this avoids drawing a marginline at all.
%    \begin{macrocode}
\newcommand{\kata@beltmargin}[2]{%
  \kata@ifstr{#1}{}{%
    \kata@ifstr{#2}{}{}{%
      \kata@beltmargin@raw{#1}{#2}%
    }%
  }{%
    \kata@beltmargin@raw{#1}{#2}%
  }%
}
%    \end{macrocode}
