% \subsection{The kataRaw environment}
% This is the low-level raw kata environment.
% It is only for wrapping the \verb|step|s and trying to generate a proper grid (by placing the correct space in the end).
%    \begin{macrocode}
\pgfkeys{
  /kata/kata,
  % not relevant for step -> adds not to memoize context
  columns/.store in = \kata@columns,
  columns = 6,
  columns/.value required,
  %
  /kata/forward/delegate common,
  /kata/forward/append common,
}
%    \end{macrocode}
%
% \begin{environment}{kataRaw}
% this environment is basically a container for a sequence of steps.
% Arguments:
% \begin{enumerate}
%   \item optional: keys from \verb|/kata/kata|
% \end{enumerate}
%    \begin{macrocode}
\NewDocumentEnvironment{kataRaw}{O{}}{%
  \pgfkeys{/kata/kata,#1}%
  \setlength{\lineskip}{6pt}%
  \stepcounter{kata@kata}%
  \kata@inkatatrue%
%    \end{macrocode}
% there is no harm in a single word/pictogram in the last line to turn off the corresponding penalty
%    \begin{macrocode}
  \widowpenalty=0
  \ignorespaces%
}{%
%    \end{macrocode}
% add hidden steps to the last line.
% This ensures a uniform looking grid of pictograms
%    \begin{macrocode}
  \ifnum\kata@columns=0\else%
    \pgfmathtruncatemacro{\kata@missing}{mod(\kata@columns - mod(\value{kata@step},\kata@columns),\kata@columns)}%
    \ifnum\kata@missing>0
      \foreach \i in {1,...,\kata@missing} {%
        \kataStepPhantom%
      }%
    \fi%
  \fi%
%    \end{macrocode}
% avoid left-aligning the last line. Instead it should be justified in
% order to obtain a proper grid
%    \begin{macrocode}
  \parfillskip=0pt
  \par%
}
%    \end{macrocode}
% \end{environment}
%
%
% \subsection{The kata environment}
