%    \begin{macrocode}
\RequirePackage{memoize}
\RequirePackage{pgfkeys}
\RequirePackage{coloredbelts}
\RequirePackage{tikz}
\usetikzlibrary{calc,positioning,fit,arrows.meta}
\usetikzlibrary{decorations.markings,decorations.pathmorphing,backgrounds}

\RequirePackage{scrbase}
\AtBeginDocument{%
  \@ifundefined{KOMAClassName}{%
    \PackageError{mypackage}
      {This package requires a KOMA-Script class}
      {Use scrartcl, scrreprt, or scrbook.}%
  }{}
}
%    \end{macrocode}
%
% Define marginline in case it isn't already defined (so the package works without KOMA-classes as well).
%    \begin{macrocode}
\AddToHook {begindocument} [.] {%
  \providecommand\marginline[1]{%
    \marginpar[{\raggedleft #1}]{\raggedright #1}%
  }%
}
%    \end{macrocode}
%
% \subsection{Internals}
% A counter for each pictogram to enable referencing.
%    \begin{macrocode}
\newcounter{kata@step}[section]
%    \end{macrocode}
%
%
% \subsubsection{Keys for Argparsing}
%
% define pgfkeys for arguments to defined commands (argparsing)
%    \begin{macrocode}
\newif\ifkata@flip
\newif\ifkata@first
\pgfkeys{
%    \end{macrocode}
% Arguments for content commands like \verb|stance|
%    \begin{macrocode}
  /kata/cmd/content/.cd,
  /kata/cmd/content/.search also={/tikz},
  flip/.is if=kata@flip,
  flip/.default=true,
%    \end{macrocode}
% Arguments for step env
%    \begin{macrocode}
  /kata/cmd/step/.cd,
  /kata/cmd/step/.search also={/kata/styles,/tikz},
  first/.is if=kata@first,
  first/.default=true,
  phantom/.style={
    /kata/customize/border/.style={draw=none},
    /kata/head/.style={draw=none},
    /kata/customize/stepCnt/.style={draw=none,transparent},
  },
  phantom/.meaning to context,
%    \end{macrocode}
% Arguments for kata env
%    \begin{macrocode}
  /kata/cmd/kata/.cd,
  /kata/cmd/kata/.search also={/tikz},
  width/.initial=6,
  width/.value required,
}
%    \end{macrocode}
%
%
% \subsubsection{Internal pgf/TikZ Styles}
%
% set pgf keys used when drawing the pictograms \verb|/kata| namespace
%
% style for the node placed at the center representing the head
%    \begin{macrocode}
\pgfkeys{
  /kata/.cd,
  head/.style={circle,draw=#1,inner xsep=0.333em},
  head/.meaning to context,
%    \end{macrocode}
% style for the arrow/path showing the stance
% takes two arguments to nudge the position so the path is not drawn directly on top of other paths (the \emph{waza})
%    \begin{macrocode}
  stance/.style 2 args={
    KataColorFeet,
    -{Stealth[scale=1.2]},
    transform canvas={xshift=#1,yshift=#2}
  },
  stance/.meaning to context,
%    \end{macrocode}
% style for the arrow/path showing a technique
%    \begin{macrocode}
  waza/.style={KataColorWaza,-{Stealth[scale=1.2]}},
  waza/.meaning to context,
%    \end{macrocode}
% style for the arrow/path indicating the next movement/direction
%    \begin{macrocode}
  dir/.style={KataColorDir,-{Straight Barb}},
  dir/.meaning to context,
%    \end{macrocode}
% style(s) for the node containing the description for the technique of the stance
% split up in \verb|NodeCommon|, \verb|stanceNo| and \verb|stanceNodeFlipped| so when
% the user requests to flip the node (e.g. to avoid collision with other text)
% the placement can be adjusted
%    \begin{macrocode}
  stanceNodeCommon/.style={text width=1.8cm,midway,sloped,font=\sffamily\scriptsize},
  stanceNodeCommon/.meaning to context,
  stanceNode/.style={/kata/stanceNodeCommon,below,},
  stanceNode/.meaning to context,
  stanceNodeFlipped/.style={/kata/stanceNodeCommon,above,},
  stanceNodeFlipped/.meaning to context,
%    \end{macrocode}
% style(s) for the node containing the description for a technique
% split up in \verb|NodeCommon|, \verb|stanceNo| and \verb|stanceNodeFlipped| so when
% the user requests to flip the node (e.g. to avoid collision with other text)
% the placement can be adjusted
%    \begin{macrocode}
  wazaNodeCommon/.style={text width=1.8cm,midway,sloped,font=\sffamily\scriptsize},
  wazaNodeCommon/.meaning to context,
  wazaNode/.style={/kata/wazaNodeCommon,above,},
  wazaNode/.meaning to context,
  wazaNodeFlipped/.style={/kata/wazaNodeCommon,below,},
  wazaNodeFlipped/.meaning to context,
%    \end{macrocode}
% style for the border enclosing the pictogram
% takes the color as argument
%    \begin{macrocode}
  border/.style={
    rectangle,
    draw=#1,
    fit=(output),
    inner sep=0pt,outer sep=0pt,inner xsep=0.2em
  },
  border/.meaning to context,
%    \end{macrocode}
% style for the node showing the number of the current step
%    \begin{macrocode}
  stepCnt/.style={
    outer sep=0pt,
    at={(t1.north west)},
    below right,
    rectangle,
    draw,
    font=\sffamily\small
  },
  stepCnt/.meaning to context,
}
%    \end{macrocode}
%
%
% \subsubsection{Internal Elements of the Pictograms}
%
% \begin{macro}{\kata@nothing}
% ensure the box is always at least the same size (internal command + always placed)
%    \begin{macrocode}
\NewDocumentCommand{\kata@nothing}{}{
  \draw[draw=none] (head) -- ++(0:2.15) -- ++(180:4.3) -- ++(90:2.15) -- ++(-90:4.3);
}
%    \end{macrocode}
% \end{macro}
% \begin{macro}{\kata@head}
% draw the circle symbolizing the head (internal command + always placed)
%    \begin{macrocode}
\NewDocumentCommand{\kata@head}{}{
  \node[/kata/head,/kata/customize/head] (head) {};
}
%    \end{macrocode}
% \end{macro}
%
%
% \subsubsection{Helpers}
%
% \begin{macro}{\kata@requirestep}
% enforces something is run within the step environment (helper)
%    \begin{macrocode}
\newif\ifkata@instep
\NewDocumentCommand{\kata@requirestep}{m}{%
  \ifkata@instep\else
    \PackageError{kata}{#1 used outside step environment}{}
  \fi
}
%    \end{macrocode}
% \end{macro}
% \begin{macro}{\kata@requirekata}
% enforces something is run within the kata environment (helper)
%    \begin{macrocode}
\newif\ifkata@inkata
\NewDocumentCommand{\kata@requirekata}{m}{%
  \ifkata@inkata\else
    \PackageError{kata}{#1 used outside kata environment}{}
  \fi
}
%    \end{macrocode}
% \end{macro}
%
% \subsubsection{Draw the Marginline}
% \begin{macro}{\kata@beltMargin}
%    \begin{macrocode}
\NewDocumentCommand{\kata@beltMargin}{mm}{%
  \marginline{%
    \centering\footnotesize%
    \Ifstr{#1}{}{}{%
      $\downarrow$ #1%
    }%
%    \end{macrocode}
% only linebreak if both are non-empty
%    \begin{macrocode}
    \Ifstr{#1}{}{}{\Ifstr{#2}{}{}{\\}}%
    \Ifstr{#2}{}{}{%
      \ColorBelt*[scale=0.1]{#2}%
    }%
  }%
}
%    \end{macrocode}
% \end{macro}
