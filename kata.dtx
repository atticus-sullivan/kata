% \subsubsection{Typical content commands} \label{sec:opt-typ-content}
% Similarly like for global options there is a set of options which apply to all \emph{typical} content commands.
% \emph{Typical} here refers to content commands which draw something and also have a label.
% In particular \refCom{kataDir} does not count as \emph{typical} as it draw no label.
%
% \begin{docKeys}[doc keypath=kata, doc description={bool, initially: false, default: true}]{{doc name=waza/flip},{doc name=stance/flip}}
%   Flips the respective label to the other side.
% \end{docKeys}
%
% \begin{docKeys}[doc keypath=kata]{{doc name=waza/style},{doc name=stance/style}}
