% \begin{docCommand}[]{kataStepPhantom}{}
%   Places a phantom/invisible \refEnv{step} which can be used to \enquote{skip} one place in the grid.
%   This is exactly what \refEnv{kataRaw} potentially appends to the last line in order to generate a proper grid.
