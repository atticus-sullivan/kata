% \subsubsection{Styles}
% Define some styles for the user to customize the output
%
% \paragraph{Level 1 -- Beginner}
% \begin{macro}{\katastyle}
% A command for setting \verb|/kata/styles| keys similar like \verb|\tikzset|
%    \begin{macrocode}
\NewDocumentCommand{\katastyle}{m}{%
  \pgfkeys{/kata/styles/.cd,#1}%
  \ignorespaces%
}
%    \end{macrocode}
% \end{macro}
%    \begin{macrocode}
\pgfkeys{
%    \end{macrocode}
% Styles for the pictogram-border ($\to$ \verb|/kata/customize/border|)
%    \begin{macrocode}
  /kata/styles/border/.cd,
%    \end{macrocode}
% draw arrows to the right on the border, takes the color as argument
%    \begin{macrocode}
  right/.style={
    /kata/customize/border/.style={fill=#1!5,draw=#1,/kata/border/arrowRL=-90},
  },
  right/.meaning to context,
%    \end{macrocode}
% draw arrows to the left on the border, takes the color as argument
%    \begin{macrocode}
  left/.style={
    /kata/customize/border/.style={fill=#1!5,draw=#1,/kata/border/arrowRL=+90},
  },
  left/.meaning to context,
%    \end{macrocode}
% draw arrows to the top on the border, takes the color as argument
%    \begin{macrocode}
  up/.style={
    /kata/customize/border/.style={fill=#1!5,draw=#1,/kata/border/arrowUD=0},
  },
  up/.meaning to context,
%    \end{macrocode}
% draw arrows to the bottom on the border, takes the color as argument
%    \begin{macrocode}
  down/.style={
    /kata/customize/border/.style={fill=#1!5,draw=#1,/kata/border/arrowUD=180},
  },
  down/.meaning to context,
%    \end{macrocode}
% resets the border modifications
%    \begin{macrocode}
  reset/.style={/kata/customize/border/.style={}},
  reset/.meaning to context,
}
%    \end{macrocode}
%
%
% \paragraph{Level 2 -- Advanced}
% define pgfkeys designed for cosmetic adjustments of the pictograms \verb|/kata| namespace
%    \begin{macrocode}
\pgfkeys{
  /kata/customize/.cd,
%    \end{macrocode}
% executed after \verb|/kata/stepCnt|
%    \begin{macrocode}
  stepCnt/.style={},
  stepCnt/.meaning to context,
%    \end{macrocode}
% executed after \verb|/kata/head|
%    \begin{macrocode}
  head/.style={},
  head/.meaning to context,
%    \end{macrocode}
% executed after \verb|/kata/dir|
%    \begin{macrocode}
  dir/.style={},
  dir/.meaning to context,
%    \end{macrocode}
% executed after \verb|/kata/border|
%    \begin{macrocode}
  border/.style={},
  border/.meaning to context,
}
%    \end{macrocode}
%
% \subparagraph{Helpers for the border}
% auxilary keys to be used in the \verb|customize/border| style
%
%    \begin{macrocode}
\pgfkeys{
  /kata/border/.cd,
  arrowRL/.style={
    postaction={decorate},decoration={
      markings,
      mark=at position 0.125
        with {\pgftransformrotate{#1 - 270}\arrow[line width=2pt]{stealth}},
      mark=at position 0.625
        with {\pgftransformrotate{#1 - 270}\arrowreversed[line width=2pt]{stealth}},
    },
  },
  arrowRL/.meaning to context,
  arrowUD/.style={
    postaction={decorate},decoration={
      markings,
      mark=at position 0.375
        with {\pgftransformrotate{#1}\arrow[line width=2pt]{stealth}},
      mark=at position 0.875
        with {\pgftransformrotate{#1}\arrowreversed[line width=2pt]{stealth}},
    },
  },
  arrowUD/.meaning to context,
}
%    \end{macrocode}
