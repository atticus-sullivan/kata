% \begin{docKeys}[doc keypath=kata]{{doc name=waza/label},{doc name=stance/label}}
%   Appends to the respective style for the label of the component.
%   Only adjusts the style for this single invocation (scoping).
%
%   The style only applies to \emph{non-flipped} labels.
% \end{docKeys}
%
% \begin{docKeys}[doc keypath=kata]{{doc name=waza/label flipped},{doc name=stance/label flipped}}
%   Similar like \refKey{/kata/waza/label} etc.
%
%   The style only applies to \emph{flipped} labels.
% \end{docKeys}
%
% \begin{docKeys}[doc keypath=kata]{{doc name=waza/color},{doc name=stance/color}}
%   Sets the respective color for the component.
%
%   Under the hood this forwards to the respective key in \refKey{/kata/color/waza} etc.
% \end{docKeys}
