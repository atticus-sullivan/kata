% \maketitle
%
% \begin{abstract}
% The \texttt{kata} package provides a compact and structured way to typeset
% martial arts katas\footnote{\url{https://en.wikipedia.org/wiki/Kata}} (forms)
% in \LaTeX{}. It models a kata as a sequence of steps, each combining the stance
% hand/foot technique, and transition direction, and supports
% customizing the resulting pictograms for clear visual representation.
% \end{abstract}
%
% \section{Introduction}
% In many martial arts such as Karate, a kata is a predefined sequence of
% movements\footnote{\url{https://en.wikipedia.org/wiki/Kata}}.
%
% The \texttt{kata} package aims to provide a simple, structured way to
% describe katas in \LaTeX{}. Each step of a kata is expressed as a step
% consisting of
% \begin{enumerate}
%   \item the stance with direction
%   \item a technique with direction
%   \item the direction of movement or rotation into the next step
% \end{enumerate}
% The package also offers customizing the resulting pictograms, allowing visual
% annotation of sequences, such as highlighting repetitions or emphasizing
% specific actions.
%
% \section{Usage / Quick-Start}
% Load this package as \verb|\usepackage[<options>]{kata}|.
%
% This section documents every command and environment which mostly is all you need to know to start using this package.
% Together with the simple example (see \cref{sec:simple-example}) this should get you working.
%
% Then, you can look up customization options later in \cref{sec:options} (either by reading everything or following the links embedded in this section).
%
% \label{sec:general-angle}
% \begin{tcolorbox}[title={Note: Orientation of the \emph{angle}s in the arguments},fonttitle=\sffamily\bfseries,colframe=orange]
%   Some commands such as \refCom{kataWaza}, \refCom{kataDir}, and \refCom{kataStance} can/must be passed angles in the range of -360 to 360 degrees.
%   Also some pgfkeys take a angles as an argument.
%
%   This package consistently defines the orientation of these angles as follows:
%
%   \centering
%   \begin{tikzpicture}
%     \node[circle,draw] (origin) {};
%     \foreach \i/\t/\d in {0/{-90/270}/right, 90/0/above, 180/90/left, 270/180/below}{
%       \node[\d] (\i) at (\i:1) {\t};
%       \draw[-{Stealth}] (origin) -- (\i);
%     }
%   \end{tikzpicture}
% \end{tcolorbox}
%
% \subsection{Package arguments}
% This package supports passing package-options.
%
% See \cref{sec:options} for the available \meta{options}.
%
% \begin{docCommand}[]{kataSetup}{\oarg{options}}
%   This can set exactly the same options like with the package-options.
%   You can either use this to set package-options at a later point in time in the preamble.
%
%   But you can also use this to set options mid-document.
%   Note that these options are then local to that scope.
%   You can leverage this to change the style of a sequence of \refEnv{kataStep}s \enquote{globally} (see also \cref{sec:extended-example}).
% \end{docCommand}
%
% \begin{docCommand}[]{kataAliases}{}
%   Defines the following aliases for ease of use:
%
%   \begin{docCommand}[]{stance}{\oarg{side}\marg{content}\marg{dir}\oarg{options}}
%     an alias for \refCom{kataStance}
%   \end{docCommand}
%   \begin{docCommand}[]{waza}{\oarg{side}\marg{content}\marg{dir}\oarg{options}}
%     an alias for \refCom{kataWaza}
%   \end{docCommand}
%   \begin{docCommand}[]{dir}{\oarg{options}\marg{angleA}\marg{angleB}}
%     an alias for \refCom{kataDir}
%   \end{docCommand}
%   \begin{docCommand}[]{kiai}{\marg{angle}}
%     an alias for \refCom{kataKiai}
%   \end{docCommand}
%   \begin{docEnvironment}[]{step}{\oarg{options}}
%     an alias for \refEnv{kataStep}
%   \end{docEnvironment}
%
%   Defining the aliases is deferred until the begin of the document.
%   Each alias is only defined if the corresponding macro is not already defined (otherwise a warning is shown in the log)
%
%   At the moment, this option only has an effect when given in the preamble (via \refCom{kataSetup}) or in the package-options.
% \end{docCommand}
%
% \subsection{Specifying a kata}
%
% \begin{docEnvironment}[]{kata}{\oarg{options}}
% The environment which holds an entire kata.
% Within it, normal \LaTeX{} code can be typeset.
% Mostly the content usually consists of \refEnv{kataStep} environments each representing one step in the kata.
%
% Depending on the \meta{options}, this will also add various additional elements such as a section or a marginline.
%
% See \cref{sec:options} for the available \meta{options}.
%
% Internally this environment uses \refEnv{kataRaw}.
% Thus, the remarks on that environment are also relevant for this one (particularly regarding how the grid is formed and the relevance of \refKey{/kata/kata/columns}).
% \end{docEnvironment}
%
% \begin{docEnvironment}[]{kataRaw}{\oarg{options}}
% This is the lightweight variant of \refEnv{kata}.
% Similarly it also holds an entire kata.
% The huge difference is it does \emph{no additional styling of the kata}.
%
% See \cref{sec:options} for the available \meta{options}.
%
% It just places the steps and tries to generatr a proper grid of \refEnv{step}s.
% In order to do so, this environment automatically adds phantom/invisible \verb|\rule|s in the end which are supposed to fill up the last line of \refEnv{step}s.
% For this reason, it is crucial \refKey{/kata/kata/columns} is set to the amount of \refEnv{step}s fitting onto one line.
% This setting is used to determine in which column the current \refEnv{step} shall be placed which is a requirement for the correct spacing.
% Also it is necessary in order to determine the amount of \verb|\rule|s which need to be placed in the end.
%
% Notes:
% \begin{itemize}
%   \item You can set \refKey{/kata/kata/columns} to \texttt{0} which \emph{disables many automatisms}.
%     As a result, between every \refEnv{step} a simple \verb|\hskip 0.0pt plus 1.0fil| is placed no matter what the current column is.
%     Also, this disables the automatic placement of \verb|\rule|s in the end (you may of course still padd manually with \refCom{kataStepPhantom}s.
% \end{itemize}
% \end{docEnvironment}
%
% \begin{docEnvironment}[]{kataStep}{\oarg{options}}
% Draws a pictogram representing one step in the kata.

% See \cref{sec:options} for the available \meta{options}.
%
% The body will be the content of a \verb|tikzpicture| so normal \LaTeX{} code won't work as expected.
% Instead, if you want/need to, you can draw arbitraty \TikZ{} code in this environment.
%
% Notes:
% \begin{itemize}
%   \item
%     The circle representing the \emph{head}, is drawn right at the start of this environment as a node named \emph{head}.
%     You may use it as a regular \TikZ{} node when writing custom \TikZ{}-code.
%     The advice is not to draw out of the normal bounds as this will break the alignment of the pictograms.
%   \item
%     The counter which is also normally shown in the top left corner of each step also adds a \emph{reference point}.
%     In effect, you can use \verb|\label| to label a step and reference that step later with the typical \LaTeX{} mechanisms.
% \end{itemize}
%
% Usually you'll use \refCom{kataWaza}, \refCom{kataStance} and \refCom{kataDir} to populate the step with contents.
% Note that all of these commands may be present (multiple times) but they don't need to be present all.
% \end{docEnvironment}
%
% \begin{docCommand}[]{kataWaza}{\oarg{side}\marg{content}\marg{dir}\oarg{options}}
% Use this command to draw a technique with its direction.
%
% Note: This command is quite similar to \refCom{kataStance}.
%
% \begin{description}
%   \item[\meta{side}] may specify the side (R/L or right/left) which executes the technique (arbitrary text is allowed here)
%   \item[\meta{content}] the text describing the action
%   \item[\meta{angle}] the angle in which to execute the action.
%     See \cref{sec:general-angle} for more details.
%   \item[\meta{options}] see \cref{sec:opt-waza} for the available \meta{options}.
%     The most common option probably here is \refKey{/kata/waza/flip}.
% \end{description}
% \end{docCommand}
%
% \begin{docCommand}[]{kataStance}{\oarg{side}\marg{content}\marg{dir}\oarg{options}}
% Use this command to draw the technique+direction for the stance.
%
% Note: This command is quite similar to \refCom{kataWaza}.
%
% \begin{description}
%   \item[\meta{side}] may specify the side (R/L or right/left) which executes the technique (arbitrary text is allowed here)
%   \item[\meta{angle}] the angle in which to execute the action.
%     See \cref{sec:general-angle} for more details.
%   \item[\meta{dir}] the direction in which to execute the action
%   \item[\meta{options}] see \cref{sec:opt-stance} for the available \meta{options}.
%     The most common option probably here is \refKey{/kata/stance/flip}.
% \end{description}
% \end{docCommand}
%
% \begin{docCommand}[]{kataDir}{\oarg{options}\marg{angleA}\marg{angleB}}
% Use this command to draw an indicator indicating the direction/turn to transition to the next step.
%
% See \cref{sec:general-angle} for more details on the notion of angles.
%
% \begin{description}
%   \item[\meta{options}] see \cref{sec:opt-dir} for the available \meta{options}.
%     The most common option probably here is \refKey{/kata/dir/flip}.
%   \item[\meta{angleA}] is where the movement starts (in degrees -360 to 360)
%   \item[\meta{angleB}] is where the movement ends (in degrees -360 to 360)
% \end{description}
%
% Note for \meta{angleA} the string \emph{center} is also eligible.
% This causes the arrow to start at the center of the circle/head, indicating only a direction not a turn.
% \end{docCommand}
%
% \begin{docCommand}[]{kataKiai}{\marg{angle}}
% Use this command to draw an indicator that this step involves \emph{kiai}.
%
% The \meta{angle} specifies at which angle to place this indicator.
% This package does not keep track how full the pictogram already is.
% Thus, you need to manually check at which angle there is space for this indicator to be placed.
% \end{docCommand}
%
% \subsection{Simple Example} \label{sec:simple-example}
% Note:
% The output looks slightly different in the example's output here.
% Usually, the section is a proper section and the marginline is really show in the margin.
%
% {\installMocks % Mocks are only used here in the docs avoid problems showing this inside the example box
%<*doc>
\begin{dispExample*}{listing options={language=[LaTeX]TeX},breakable,title={A simple example without customizations (but includes flip)}}
\kataSetup{styled kata={section,margin,belt},columns=2}

\begin{kata}[belt color=blue,title={Simple Example}]
  Some explanation -- normal \LaTeX{} code
  \parindent=0pt

  \begin{step}
    \stance{stance A}{0}
    \waza{technique A}{-90}
    \dir{center}{90}
  \end{step}
  \begin{step}
    \stance{stance A}{0}
    \dir{90}{-90}
  \end{step}
  \begin{step}
    \stance{stance A}{0}[flip]
    \dir[flip]{90}{-90}
  \end{step}
\end{kata}
\end{dispExample*}
%</doc>
% }
%
% \begin{docCommand}[]{kataStepCnt}{\marg{counter}}
% Formats the counter holding the number of the current step.
% Adjust this with e.g. \verb|\RenewDocumentCommand| or \verb|renewcommand| to change how the counter is displayed.
% \end{docCommand}
%
% \subsection{Options / Customization} \label{sec:options}
% The idea is you can set any option with any command (offering generic \meta{options}) which makes sense at this place.
% For example you can set the style in which the \emph{border} of a step is drawn at the \refEnv{kataStep}, \refEnv{kataRaw} and \refCom{kataSetup}/package level all with varying scopes.
% But you cannot set the \emph{border} style at the \refCom{kataWaza} or \refCom{kataStance} level as it does not make sense.
%
% Note: You should never needs to specify paths manually when specifying options.
%       As long as you are only setting options which are valid for that command, it suffices to specify the last component of the path
%       (e.g. when setting \refKey{/kata/stance/flip} in \refCom{kataStance}, it suffices to speficy the option as \verb|flip|).
%
% Structuring the options, it became evident there are groups of commands/environments which should accept a common set of options following that logic.
% These are described in \cref{sec:opt-common}.
% \Cref{sec:opt-setup,sec:opt-raw-kata,sec:opt-styled-kata,sec:opt-step,sec:opt-typ-content,sec:opt-atyp-content} describe options specific to the commands/environments.
%
% \subsubsection{Common options} \label{sec:opt-common}
% These options can be applied at \refEnv{kataStep}, \refEnv{kataRaw} and \refCom{kataSetup}/package level.
%
% \begin{docKeys}[doc keypath=kata,doc parameter={=\meta{options}}]{{doc name=setup/stance},{doc name=kata/stance},{doc name=step/stance}}
%   Sets the \meta{options} as if they are passed to every \refCom{kataStance} in the scope.
%
%   Scope means, e.g. if this is passed to \refEnv{kataRaw}/\refEnv{kata}, all \refCom{kataStance} commands in this kata will get these \meta{options}.
%   But for the next kata, the \meta{options} are not applied.
% \end{docKeys}
%
% \begin{docKeys}[doc keypath=kata,doc parameter={=\meta{options}}]{{doc name=setup/waza},{doc name=kata/waza},{doc name=step/waza}}
%   Similar like \refKey{/kata/setup/stance} etc.
%
%   Sets the \meta{options} as if they are passed to every \refCom{kataWaza} in the scope.
% \end{docKeys}
%
% \begin{docKeys}[doc keypath=kata,doc parameter={=\meta{options}}]{{doc name=setup/dir},{doc name=kata/dir},{doc name=step/dir}}
%   Similar like \refKey{/kata/setup/stance} etc.
%
%   Sets the \meta{options} as if they are passed to every \refCom{kataDir} in the scope.
% \end{docKeys}
%
% \begin{docKeys}[doc keypath=kata,doc parameter={=\meta{options}}]{{doc name=setup/color},{doc name=kata/color},{doc name=step/color}}
%   Use a list of the options documented in \cref{sec:ops-color} as \meta{options}.
%   Allows adjusting the colors of the various elements which are drawn.
%
%   Scoping works similar like described for \refKey{/kata/setup/stance} etc.
% \end{docKeys}
%
% \begin{docKeys}[doc keypath=kata,doc parameter={=\meta{options}}]{{doc name=setup/head style},{doc name=kata/head style},{doc name=step/head style}}
%   Appends to the syle used for the circle representing the \emph{head}.
%   You can specify arbitrary \TikZ{}-code here.
%
%   Scoping works similar like described for \refKey{/kata/setup/stance} etc.
% \end{docKeys}
%
% \begin{docKeys}[doc keypath=kata,doc parameter={=\meta{options}}]{{doc name=setup/border style},{doc name=kata/border style},{doc name=step/border style}}
%   Similar like \refKey{/kata/setup/head style} etc.
%
%   Appends the \meta{options} to the style for the border drawn around each pictogram.
% \end{docKeys}
%
% \begin{docKeys}[doc keypath=kata,doc parameter={=\meta{presets}}]{{doc name=setup/border preset},{doc name=kata/border preset},{doc name=step/border preset}}
%   Similar like \refKey{/kata/setup/head style} etc.
%   But intead of appending raw \TikZ{} options, this option allows passing \meta{presets} defined by this package for the border.
%   See \cref{sec:presets:border} for more detailled information and a list of defined border presets.
% \end{docKeys}
%
% \begin{docKeys}[doc keypath=kata,doc parameter={=\meta{presets}}]{{doc name=setup/step preset},{doc name=kata/step preset},{doc name=step/step preset}}
%   Similar like \refKey{/kata/setup/head style} etc.
%   But intead of appending raw \TikZ{} options, this option allows passing \meta{presets} defined by this package for the steps.
%   See \cref{sec:presets:step} for more detailled information and a list of defined step presets.
% \end{docKeys}
%
% \begin{docKeys}[doc keypath=kata,doc parameter={=\meta{options}}]{{doc name=setup/step counter style},{doc name=kata/step counter style},{doc name=step/step counter style}}
%   Similar like \refKey{/kata/setup/head style} etc.
%
%   Appends the \meta{options} to the style for the \TikZ{} node showing the number of the step (usually placed at the top left corner).
% \end{docKeys}
%
% \paragraph{Colors} \label{sec:ops-color}
% A collection of keys used to adjust the color used for drawing elements in the pictograms.
% As \meta{color}, everything can be passed here which \TikZ{} can use as a color.
%
% \begin{docKey}[kata/color]{stance}{=\meta{color}}{}
%   The color used for the arrow showing the direction of the stance as well as the label on this arrow.
% \end{docKey}
%
% \begin{docKey}[kata/color]{waza}{=\meta{color}}{}
%   The color used for the arrow showing the direction of the waza as well as the label on this arrow.
% \end{docKey}
%
% \begin{docKey}[kata/color]{dir}{=\meta{color}}{}
%   The color used for the arrow showing the next direction/turn for transitioning to the next step.
% \end{docKey}
%
% \begin{docKey}[kata/color]{head}{=\meta{color}}{}
%   The color used for the circle representing the head.
% \end{docKey}
%
% \begin{docKey}[kata/color]{border}{=\meta{color}}{}
%   The color used for the border around the step.
% \end{docKey}
%
% \begin{docKey}[kata/color]{step counter}{=\meta{color}}{}
%   The color used for the node (border + content) showing the number of the step.
% \end{docKey}
%
% \subsubsection{Package/Setup specific} \label{sec:opt-setup}
% These options are specific to the package-options and \refCom{kataSetup}.
%
% \begin{docKey}[kata/setup]{columns}{=\meta{columns}}{initially: 6}
%   Similar like \refKey{/kata/kata/columns}.
% \end{docKey}
%
% \begin{docKey}[kata/setup]{definealiases}{}{cmd-key}
%   Defines the same aliases like \refCom{kataAliases} when set.
%
%   Defining the aliases is deferred until the begin of the document.
%   Each alias is only defined if the corresponding macro is not already defined (otherwise a warning is shown in the log)
%
%   At the moment, this option only has an effect when given in the preamble (via \refCom{kataSetup}) or in the package-options.
% \end{docKey}
%
% \begin{docKey}[kata/setup]{styled kata}{}{}
%   Similar like \refKey{/kata/setup/stance} etc.
%
%   Sets the \meta{options} as if they are passed to every \refEnv{kata} (which is referred to as \emph{styled kata} here in contrast to a \emph{raw kata}) in the scope.
% \end{docKey}
%
% \subsubsection{Raw Kata environment} \label{sec:opt-raw-kata}
% These options are specific to \refEnv{kataRaw}.
%
% \begin{docKey}[kata/kata]{columns}{=\meta{columns}}{initially: 6}
%   Sets the amount of pictograms which fit one line in the document.
%   As of now this package cannot measure this on its own so you need to set this manually (usually only once for the whole document via \refKey{/kata/setup/columns}).
%
%   The effect of this is that at the end of a \refEnv{kataRaw}, if the last line is not fully populated, it is filled up with \verb|\rule|s with the width of one \refEnv{step}.
%   In order to know if and if yes how many places need to be filled, this key is required.
%   This is needed if you want a proper grid of pictograms in the output.
%
%   Note by setting this key to 0, you can deactivate this behavior.
% \end{docKey}
%
% \subsubsection{Styled Kata environment} \label{sec:opt-styled-kata}
% These options are specific to \refEnv{kata}.
% Note you can also pass keys from \verb|/kata/kata| here (including common options \cref{sec:opt-common}).
% As long as no key with the same name is defined here, the key (+value) will be forwarded to \verb|/kata/kata|.
%
% \paragraph{Section}
% These keys are all about the sectioning.
%
% \begin{docKey}[kata/kata/styled]{section}{}{(initially: false, default: true)}
%   Determines whether to generate a section at all at the beginning of the \refEnv{kata}.
% \end{docKey}
% \begin{docKey}[kata/kata/styled]{no section}{}{}
%   Shortcut for specifying \refKey{/kata/kata/styled/section}\verb|=false|
% \end{docKey}
% 
% \begin{docKey}[kata/kata/styled]{title}{}{}
%   The title/name of the kata.
%   This is the content for the section (if it was enabled, see \refKey{/kata/kata/styled/section}).
% \end{docKey}
%
% \begin{docCommand}[]{kataSection}{}
%   The command with which the section is generated.
%   The usual use-case of changing this key probably is to generate a \emph{subsection} instead a \emph{section} or similar changes.
%
%   Adjust it by using e.g. \verb|\renewcommand[1]{\subsection{#1}}|.
%
%   Note, the specified macro must handle exactly one argument.
% \end{docCommand}
%
% \paragraph{Margin}
% These keys decide whether and if so what content to place in a marginline generated at the begin of the \refEnv{kata}.
%
% \begin{docKey}[kata/kata/styled]{margin}{}{(initially: false, default: true)}
%   Determines whether to place a marginline at all at the beginning of the \refEnv{kata}.
% \end{docKey}
% \begin{docKey}[kata/kata/styled]{no margin}{}{}
%   Shortcut for specifying \refKey{/kata/kata/styled/margin}\verb|=false|
% \end{docKey}
%
% \begin{docKey}[kata/kata/styled]{belt}{}{(initially: false, default: true)}
%   Determines if the note in the margin (if enabled, see \refKey{/kata/kata/styled/margin}) should contain an indicator with the belt color.
% \end{docKey}
% \begin{docKey}[kata/kata/styled]{no belt}{}{}
%   Shortcut for specifying \refKey{/kata/kata/styled/belt}\verb|=false|
% \end{docKey}
%
% \begin{docKey}[kata/kata/styled]{belt color}{}{}
%   The belt color for the indicator set in the note in the margin (in case this indicator as well as the margin are enabled, see \refKey{/kata/kata/styled/margin} and \refKey{/kata/kata/styled/belt}).
% \end{docKey}
%
% \begin{docKey}[kata/kata/styled]{note}{}{}
%   A note which is placed in the margin at the beginning of the \refEnv{kata}.
%   Is only placed if the margin was enabled (see \refKey{/kata/kata/styled/margin}).
%
%   \emph{Note:} If the belt indicator was enabled (\refKey{/kata/kata/styled/belt}) but no belt color was set (\refKey{/kata/kata/styled/belt color}), the value of this key is used as fallback for the belt color.
% \end{docKey}
