    draw=\kata@color@dir,
    -{Straight Barb},
  },
  %
  border/.style = {
    rectangle,
    draw=\kata@color@border,
    fit=(output),
    inner sep=0pt,
    outer sep=0pt,
    inner xsep=0.2em,
  },
  %
  border preset/.code={
    \pgfkeysalso{/kata/preset/border,#1}%
  },
  %
  step counter/.style = {
    draw=\kata@color@stepcounter,
    font=\sffamily\small,
    outer sep=0pt,
    at={(t1.north west)},
    below right,
    rectangle,
  },
}
