%    \begin{macrocode}
\pgfkeys{
  /kata/kata/styled,
  /kata/kata/styled/.search also={/kata/kata},
  % not relevant for step -> adds not to memoize context
  section/.is if = kata@show@section,
  section/.default = true,
  section = false,
  no section/.style={/kata/kata/styled/section=false},
  %
  title/.store in = \kata@title,
  title = {},
  title/.value required,
  %
  %
  margin/.is if = kata@show@margin,
  margin/.default = true,
  margin = false,
  no margin/.style={/kata/kata/styled/margin=false},
  %
  belt/.is if = kata@show@belt,
  belt/.default = true,
  belt = false,
  no belt/.style={/kata/kata/styled/belt=false},
  %
  belt color/.store in = \kata@belt,
  belt color = {},
  belt color/.value required,
  %
  note/.store in = \kata@note,
  note = {},
  note/.value required,
}
%    \end{macrocode}
%
% \begin{environment}{kata}
% this environment is basically a container for a sequence of steps. TODO
% Arguments:
% \begin{enumerate}
%   \item optional: keys from \verb|/kata/kata|
% \end{enumerate}
%    \begin{macrocode}
\NewDocumentEnvironment{kata}{O{}}{%
  \pgfkeys{/kata/kata/styled,#1}%
  \ifkata@show@section%
    \kataSection{\kata@title}%
  \fi%
  \ifkata@show@margin%
    \ifkata@show@belt%
      \ifx\kata@belt\@empty%
        \kata@beltmargin{\kata@note}{\kata@note}%
      \else%
        \kata@beltmargin{\kata@note}{\kata@belt}%
      \fi%
    \else%
      \kata@beltmargin{\kata@note}{}%
    \fi%
  \fi%
  \begin{kataRaw}%
  \ignorespaces%
}{%
  \end{kataRaw}%
}
%    \end{macrocode}
% \end{environment}
