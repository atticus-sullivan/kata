\RequirePackage{memoize}
\RequirePackage{pgfkeys}
\RequirePackage{coloredbelts}
\RequirePackage{tikz}
\usetikzlibrary{calc,positioning,fit,arrows.meta}
\usetikzlibrary{decorations.markings,backgrounds}

\RequirePackage{scrbase}
\AtBeginDocument{%
  \@ifundefined{KOMAClassName}{%
    \PackageError{mypackage}
      {This package requires a KOMA-Script class}
      {Use scrartcl, scrreprt, or scrbook.}%
  }{}
}
%    \end{macrocode}
%
% \subsection{Internals}
% A counter for each pictogram to enable referencing.
%    \begin{macrocode}
\newcounter{kata@step}[section]
%    \end{macrocode}
%
%
% \subsubsection{Keys for Argparsing}
%
% define pgfkeys for arguments to defined commands (argparsing)
%    \begin{macrocode}
\newif\ifkata@flip
\newif\ifkata@first
\pgfkeys{
%    \end{macrocode}
% Arguments for content commands like \verb|feet|
%    \begin{macrocode}
	/kata/cmd/content/.cd,
	flip/.is if=kata@flip,
	flip/.default=true,
%    \end{macrocode}
% Arguments for step env
%    \begin{macrocode}
	/kata/cmd/step/.cd,
	first/.is if=kata@first,
	first/.default=true,
	phantom/.style={
		/kata/customize/border/.style={draw=none},
		/kata/head/.style={draw=none},
		/kata/customize/stepCnt/.style={draw=none,transparent},
	},
	phantom/.meaning to context,
%    \end{macrocode}
% Arguments for kata env
%    \begin{macrocode}
	/kata/cmd/kata/.cd,
	width/.initial=6,
	width/.value required,
}
%    \end{macrocode}
%
%
% \subsubsection{Internal pgf/TikZ Styles}
%
% set pgf keys used when drawing the pictograms \verb|/kata| namespace
%
% style for the node placed at the center representing the head
%    \begin{macrocode}
\pgfkeys{
	/kata/.cd,
	head/.style={circle,draw=#1,inner xsep=0.333em},
	head/.meaning to context,
%    \end{macrocode}
% style for the arrow/path showing the technique for the feet
% takes two arguments to nudge the position so the path is not drawn directly on top of other paths (the \emph{hand})
%    \begin{macrocode}
	feet/.style 2 args={
		KataColorFeet,
		-{Stealth[scale=1.2]},
		transform canvas={xshift=#1,yshift=#2}
	},
	feet/.meaning to context,
%    \end{macrocode}
% style for the arrow/path showing the technique for the hand
%    \begin{macrocode}
	hand/.style={KataColorHand,-{Stealth[scale=1.2]}},
	hand/.meaning to context,
%    \end{macrocode}
% style for the arrow/path indicating the next movement/direction
%    \begin{macrocode}
	move/.style={KataColorDir,->},
	move/.meaning to context,
%    \end{macrocode}
% style(s) for the node containing the description for the technique of the feet
% split up in \verb|NodeCommon|, \verb|feetNo| and \verb|feetNoFlipped| so when
% the user requests to flip the node (e.g. to avoid collision with other text)
% the placement can be adjusted
%    \begin{macrocode}
	feetNodeCommon/.style={text width=1.8cm,midway,sloped,font=\sffamily\scriptsize},
	feetNodeCommon/.meaning to context,
	feetNo/.style={/kata/feetNodeCommon,below,},
	feetNo/.meaning to context,
	feetNoFlipped/.style={/kata/feetNodeCommon,above,},
	feetNoFlipped/.meaning to context,
%    \end{macrocode}
% style(s) for the node containing the description for the technique of the hand
% split up in \verb|NodeCommon|, \verb|feetNo| and \verb|feetNoFlipped| so when
% the user requests to flip the node (e.g. to avoid collision with other text)
% the placement can be adjusted
%    \begin{macrocode}
	handNodeCommon/.style={text width=1.8cm,midway,sloped,font=\sffamily\scriptsize},
	handNodeCommon/.meaning to context,
handNo/.style={/kata/handNodeCommon,above,},
	handNo/.meaning to context,
	handNoFlipped/.style={/kata/handNodeCommon,below,},
	handNoFlipped/.meaning to context,
%    \end{macrocode}
% style for the border enclosing the pictogram
% takes the color as argument
%    \begin{macrocode}
	border/.style={
		rectangle,
		draw=#1,
		fit=(output),
		inner sep=0pt,outer sep=0pt,inner xsep=0.2em
	},
	border/.meaning to context,
%    \end{macrocode}
% style for the node showing the number of the current step
%    \begin{macrocode}
	stepCnt/.style={
		outer sep=0pt,
		at={(t1.north west)},
		below right,
		rectangle,
		draw,
		font=\sffamily\small
	},
	stepCnt/.meaning to context,
}
%    \end{macrocode}
%
%
% \subsubsection{Internal Elements of the Pictograms}
%
% ensure the box is always at least the same size (internal command + always placed)
%    \begin{macrocode}
\NewDocumentCommand{\kata@nothing}{}{
	\draw[draw=none] (head) -- ++(0:2.15) -- ++(180:4.3) -- ++(90:2.15) -- ++(-90:4.3);
}
%    \end{macrocode}
% draw the circle symbolizing the head (internal command + always placed)
%    \begin{macrocode}
\NewDocumentCommand{\kata@head}{}{
	\node[/kata/head] (head) {};
}
%    \end{macrocode}
%
%
% \subsubsection{Helpers}
%
% enforces something is run within the step environment (helper)
%    \begin{macrocode}
\newif\ifkata@instep
\NewDocumentCommand{\kata@requirestep}{m}{%
	\ifkata@instep\else
		\PackageError{kata}{#1 used outside step environment}{}
	\fi
}
%    \end{macrocode}
% enforces something is run within the kata environment (helper)
%    \begin{macrocode}
\newif\ifkata@inkata
\NewDocumentCommand{\kata@requirekata}{m}{%
	\ifkata@inkata\else
		\PackageError{kata}{#1 used outside kata environment}{}
	\fi
}
%    \end{macrocode}
%
% \subsubsection{Draw the Marginline}
%    \begin{macrocode}
\NewDocumentCommand{\kata@beltMargin}{mm}{%
	\marginline{%
		\centering\footnotesize%
		\Ifstr{#1}{}{}{%
			$\downarrow$ #1%
		}%
%    \end{macrocode}
% only linebreak if both are non-empty
%    \begin{macrocode}
		\Ifstr{#1}{}{}{\Ifstr{#2}{}{}{\\}}%
		\Ifstr{#2}{}{}{%
			\ColorBelt*[scale=0.1]{#2}%
		}%
	}%
}
%    \end{macrocode}
%
%
% \subsubsection{Environments}
% this environment is basically a container for a sequence of steps.
% Arguments:
% \begin{enumerate}
% 	\item optional: keys from \verb|/kata/cmd/kata|
% 	\item kata name
% 	\item for which belt / marginline
% 	\item optional: belt color (for drawing), if empty -> not drawn, if not present use arg 3
% \end{enumerate}
%    \begin{macrocode}
\NewDocumentEnvironment{kata}{O{}mmo}{%
	\pgfkeys{/kata/cmd/kata/.cd,#1}
	\section{#2}
	\Ifstr{#3}{}{
%    \end{macrocode}
% show if arg 3 is empty but arg 4 was set
%    \begin{macrocode}
		\IfNoValueF{#4}{\kata@beltMargin{}{#4}}%
	}{%
%    \end{macrocode}
% use arg 3 as fallback if arg 4 was not set
%    \begin{macrocode}
		\kata@beltMargin{#3}{\IfNoValueTF{#4}{#3}{#4}}%
	}%
	\setlength{\lineskip}{6pt}\noindent%
	\setcounter{kata@step}{0}%
	\kata@inkatatrue%
	\ignorespaces%
	\widowpenalty=0%
}{%
%    \end{macrocode}
% add hidden steps to the last line.
% This ensures a uniform looking grid of pictograms
%    \begin{macrocode}
	\pgfmathtruncatemacro{\kata@missing}{mod(\pgfkeysvalueof{/kata/cmd/kata/width} - mod(\c@kata@step,\pgfkeysvalueof{/kata/cmd/kata/width}),\pgfkeysvalueof{/kata/cmd/kata/width})}%
	\setcounter{kata@step}{0}%
	\ifnum\kata@missing>0%
		\foreach \i in {1,...,\kata@missing} {%
			\begin{step}[phantom]\end{step} %
		}%
	\fi%
	\kata@inkatafalse%
%    \end{macrocode}
% avoid left-aligning the last line. Instead it should be justified in
% order to obtain a proper grid
%    \begin{macrocode}
	\parfillskip=0pt%
	\par%
}
%    \end{macrocode}
%
% this environment always should wrap \verb|kata@step|.
% It handles the aspects of positioning the pictogram.
% Arguments:
% 1 (optional): whether this is the first step of the kata
%    \begin{macrocode}
\NewDocumentEnvironment{step}{O{}+b}{%
	\kata@requirekata{\string\step}%
	\pgfkeys{/kata/cmd/step/.cd, first=false, #1}%
	\ifkata@first\par\nointerlineskip\vfil\else\fi%
	\begin{kata@step}%
		#2
	\end{kata@step}%
	\refstepcounter{kata@step}%
}{}
%    \end{macrocode}
%
% the environment to draw everything else in
%    \begin{macrocode}
\NewDocumentEnvironment{kata@step}{}{%
	\kata@requirekata{\string\step}%
	\begin{tikzpicture}[font=\scriptsize]%
		\begin{scope}[local bounding box=output]%
			\kata@head\kata@nothing%
			\kata@insteptrue%
}{
		\kata@instepfalse%
		\end{scope}%
%    \end{macrocode}
% Drawing the border on the background has the advantage the rectangle can be
% filled and colorize the background as well.
%    \begin{macrocode}
		\begin{scope}[on background layer]%
			\node[/kata/border,/kata/customize/border] (t1) {};%
			\node[/kata/stepCnt,/kata/customize/stepCnt] (cnt) {\kataStepCnt{kata@step}};%
		\end{scope}%
	\end{tikzpicture}%
}
%    \end{macrocode}
%
%
% \subsection{Specify the Content}
%
% draw the arrow/path showing the technique for the feet
% Usage:
% \begin{enumerate}
% 	\item (optional) side to use (L/R)
% 	\item name/text
% 	\item direction
% \end{enumerate}
%    \begin{macrocode}
\NewDocumentCommand{\feet}{O{}mmO{}}{%
	\pgfkeys{/kata/cmd/content/.cd, flip=false, #4}%
	\kata@requirestep{\string\feet}%
	\pgfmathsetmacro{\kata@dir}{#3+90}%
	\pgfmathsetmacro{\x}{abs(sin(\kata@dir))}%
	\pgfmathsetmacro{\y}{-abs(cos(\kata@dir))}%
	\IfNoValueTF{#1}{\def\kata@nodeContent{}}{\def\kata@nodeContent{#1 }}%
	\draw[/kata/feet={\x}{\y}]
		(head) -- ++(\kata@dir:2)
		node[\ifkata@flip/kata/feetNoFlipped\else/kata/feetNo\fi]
		{\hangafter=1\settowidth\hangindent{\kata@nodeContent}\kata@nodeContent#2}
	;
}
%    \end{macrocode}
%
% draw the arrow/path showing the technique for the hand.
% Arguments:
% \begin{enumerate}
% 	\item (optional) side to use (L/R)
% 	\item name/text
% 	\item direction
% \end{enumerate}
%    \begin{macrocode}
\NewDocumentCommand{\waza}{O{}mmO{}}{%
	\kata@requirestep{\string\waza}%
	\pgfkeys{/kata/cmd/content/.cd, flip=false, #4}%
	\IfNoValueTF{#1}{\def\kata@nodeContent{}}{\def\kata@nodeContent{#1 }}%
	\pgfmathsetmacro{\kata@dir}{#3+90}%
	\draw[/kata/hand]
		(head) -- ++(\kata@dir:2)
		node[\ifkata@flip/kata/handNoFlipped\else/kata/handNo\fi]
		{\hangafter=1\settowidth\hangindent{\kata@nodeContent}\kata@nodeContent#2}
	;
}
%    \end{macrocode}
%
% draw a short arrow/path indicating the next turn/direction.
% Arguments:
% \begin{enumerate}
% 	\item (optional) flip
% 	\item source (Center,angle)
% 	\item dst (angle)
% \end{enumerate}
%    \begin{macrocode}
\NewDocumentCommand{\dir}{O{}mm}{
	\kata@requirestep{\string\dir}
	\pgfkeys{/kata/cmd/content/.cd, flip=false, #1,}
	\pgfmathsetmacro{\kata@out}{#3+90}
	\Ifstr{#2}{center}{
		\draw[/kata/move] (head.center) -- ++(\kata@out:.33em);
	}{
		\pgfmathsetmacro{\kata@in}{#2+90}
		\pgfmathsetmacro{\kata@outDeltaI}{\kata@out-\kata@in}
		\ifkata@flip
			\if -\kata@outDeltaI
				\pgfmathsetmacro{\kata@outDeltaII}{360+\kata@outDeltaI}
			\else
				\pgfmathsetmacro{\kata@outDeltaII}{\kata@outDeltaI-360}
			\fi
		\else
			\pgfmathsetmacro{\kata@outDeltaII}{\kata@outDeltaI}
		\fi
		\draw[/kata/move]
			(head.center) ++ (\kata@in:.33em)
			arc[start angle=\kata@in,delta angle=\kata@outDeltaII,radius=.33em]
		;
	}
}
%    \end{macrocode}
