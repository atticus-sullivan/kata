% \subsection{For user customization}
% \subsubsection{Colors}
%
% define xcolors used for coloring elements in the pictograms
%    \begin{macrocode}
\RequirePackage{xcolor}
\colorlet{KataColorFeet}{blue}
\colorlet{KataColorHand}{green}
\colorlet{KataColorDir}{red}
